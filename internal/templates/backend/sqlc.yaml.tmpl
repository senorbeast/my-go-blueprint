version: "2"
sql:
  - engine: "{{if eq .Database "postgres"}}postgresql{{else}}mysql{{end}}"
    # The renderer selects one dialect and flattens its migrations into this
    # generated directory.
    schema: "migrations"
    queries:
      - "internal/platform/database/queries"
      - "internal/platform/ratelimit/queries"
      {{if .Auth}}- "internal/features/users/queries"
      - "internal/features/auth/queries"
      - "internal/features/organizations/queries"
      {{end}}{{if .CMS}}- "internal/features/cms/queries"
      {{end}}{{if .Jobs}}- "internal/features/jobs/queries"
      {{end}}{{if .CRM}}- "internal/features/crm/queries"
      {{end}}
    gen:
      go:
        package: "dbgen"
        out: "internal/platform/database/dbgen"
        # Bootstrap exposes database/sql handles for both dialects, so sqlc
        # output can be composed directly without a driver-specific wrapper.
        sql_package: "database/sql"
        emit_interface: true
        emit_json_tags: true
