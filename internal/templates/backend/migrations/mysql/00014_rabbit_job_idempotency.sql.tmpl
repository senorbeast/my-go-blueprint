-- RabbitMQ has at-least-once delivery but no portable broker-side deduplication.
-- This ledger allocates one durable job ID for each application idempotency key.
CREATE TABLE rabbit_job_idempotency_keys(
  idempotency_key varchar(255) PRIMARY KEY,
  job_id binary(16) NOT NULL,
  created_at timestamp(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6)
);
