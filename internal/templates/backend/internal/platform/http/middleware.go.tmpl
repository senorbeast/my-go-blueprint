package http

import (
	"context"
	"errors"
	"net/http"
	"time"

	"github.com/labstack/echo/v4"
	"github.com/labstack/echo/v4/middleware"
	"go.uber.org/zap"

	platformauth "{{.Module}}/backend/internal/platform/auth"
	"{{.Module}}/backend/internal/platform/config"
	platformerrors "{{.Module}}/backend/internal/platform/errors"
)

func InstallMiddleware(e *echo.Echo, logger *zap.Logger, cfg config.Config) {
	e.Use(middleware.RequestID())
	e.Use(middleware.Recover())
	e.Use(middleware.Secure())
	e.Use(middleware.BodyLimit("2M"))
	e.Use(middleware.CORSWithConfig(middleware.CORSConfig{
		AllowOrigins: cfg.CORSOrigins,
		AllowMethods: []string{http.MethodGet, http.MethodHead, http.MethodPost, http.MethodPut, http.MethodPatch, http.MethodDelete, http.MethodOptions},
		AllowHeaders: []string{echo.HeaderOrigin, echo.HeaderContentType, echo.HeaderAccept, echo.HeaderXRequestID, "X-CSRF-Token"},
		AllowCredentials: true,
	}))
	e.Use(middleware.TimeoutWithConfig(middleware.TimeoutConfig{Timeout: 30 * time.Second}))
	e.Use(middleware.RequestLoggerWithConfig(middleware.RequestLoggerConfig{
		LogRequestID: true, LogURI: true, LogMethod: true, LogStatus: true, LogLatency: true, LogError: true,
		LogValuesFunc: func(_ echo.Context, values middleware.RequestLoggerValues) error {
			fields := []zap.Field{zap.String("request_id", values.RequestID), zap.String("method", values.Method), zap.String("uri", values.URI), zap.Int("status", values.Status), zap.Duration("latency", values.Latency)}
			if values.Error != nil { logger.Error("http request failed", append(fields, zap.Error(values.Error))...) } else { logger.Info("http request", fields...) }
			return nil
		},
	}))
	e.HTTPErrorHandler = ProblemHandler(logger)
}

// AccessTokenVerifier is deliberately small so the HTTP boundary does not
// know which token implementation is used by bootstrap.
type AccessTokenVerifier interface { Verify(context.Context, string) (platformauth.Principal, error) }

func PrincipalMiddleware(verifier AccessTokenVerifier) echo.MiddlewareFunc {
	if verifier == nil { panic("access token verifier is required") }
	return func(next echo.HandlerFunc) echo.HandlerFunc {
		return func(c echo.Context) error {
			token := ""
			if cookie, err := c.Cookie("access_token"); err == nil { token = cookie.Value }
			if token != "" {
				principal, err := verifier.Verify(c.Request().Context(), token)
				if err != nil { return platformerrors.New(platformerrors.Unauthenticated, "invalid_access_token", "Authentication is required") }
				c.SetRequest(c.Request().WithContext(platformauth.WithPrincipal(c.Request().Context(), principal)))
			}
			return next(c)
		}
	}
}

// CSRFMiddleware uses the double-submit pattern: the readable, host-only CSRF
// cookie must match the request header for unsafe methods. Access and refresh
// cookies remain HttpOnly and are never exposed to JavaScript.
func CSRFMiddleware() echo.MiddlewareFunc {
	return func(next echo.HandlerFunc) echo.HandlerFunc {
		return func(c echo.Context) error {
			switch c.Request().Method { case http.MethodGet, http.MethodHead, http.MethodOptions, http.MethodTrace: return next(c) }
			if _, err := c.Cookie("access_token"); err != nil {
				if _, refreshErr := c.Cookie("refresh_token"); refreshErr != nil { return next(c) }
			}
			cookie, err := c.Cookie("csrf_token")
			if err != nil || cookie.Value == "" || c.Request().Header.Get("X-CSRF-Token") == "" || cookie.Value != c.Request().Header.Get("X-CSRF-Token") { return platformerrors.New(platformerrors.Forbidden, "csrf_failed", "CSRF validation failed") }
			return next(c)
		}
	}
}

func ProblemHandler(logger *zap.Logger) echo.HTTPErrorHandler {
	return func(err error, c echo.Context) {
		status, code, message := http.StatusInternalServerError, "internal", "An internal error occurred"
		var applicationError *platformerrors.Error
		if errors.As(err, &applicationError) {
			code, message = applicationError.Code, applicationError.Message
			switch applicationError.Kind {
			case platformerrors.Validation: status = http.StatusUnprocessableEntity
			case platformerrors.Unauthenticated: status = http.StatusUnauthorized
			case platformerrors.Forbidden: status = http.StatusForbidden
			case platformerrors.NotFound: status = http.StatusNotFound
			case platformerrors.Conflict: status = http.StatusConflict
			case platformerrors.RateLimited: status = http.StatusTooManyRequests
			case platformerrors.Unavailable: status = http.StatusServiceUnavailable
			}
		}
		problem := map[string]any{"type": "urn:problem:" + code, "title": http.StatusText(status), "status": status, "detail": message, "code": code, "requestId": c.Response().Header().Get(echo.HeaderXRequestID)}
		if responseErr := c.JSON(status, problem); responseErr != nil { logger.Error("write problem response", zap.Error(responseErr)) }
		if status >= 500 { logger.Error("unhandled request error", zap.Error(err), zap.String("request_id", c.Response().Header().Get(echo.HeaderXRequestID)) ) }
	}
}
