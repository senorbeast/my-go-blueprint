package cache

import (
	"context"
	"time"

	"github.com/redis/go-redis/v9"
)

type RedisStore struct { client redis.UniversalClient }

func NewRedisStore(url string) (*RedisStore, error) {
	options, err := redis.ParseURL(url)
	if err != nil { return nil, err }
	return &RedisStore{client: redis.NewClient(options)}, nil
}

func (s *RedisStore) Get(ctx context.Context, key string) ([]byte, bool, error) {
	value, err := s.client.Get(ctx, key).Bytes()
	if err == redis.Nil { return nil, false, nil }
	if err != nil { return nil, false, err }
	return value, true, nil
}

func (s *RedisStore) Set(ctx context.Context, key string, value []byte, ttl time.Duration) error { return s.client.Set(ctx, key, value, ttl).Err() }
func (s *RedisStore) Delete(ctx context.Context, key string) error { return s.client.Del(ctx, key).Err() }
func (s *RedisStore) Close() error { return s.client.Close() }
