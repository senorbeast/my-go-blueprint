package ratelimit

import (
	"context"
	"crypto/sha256"
	"database/sql"
	"fmt"
	"math"
	"time"

	"{{.Module}}/backend/internal/platform/database/dbgen"
)

// NewSQLRollingWindow creates the process-shared limiter used by bootstrap.
// A nil database deliberately retains the in-process implementation for
// command/test compositions that have no database lifecycle.
func NewSQLRollingWindow(db *sql.DB, now func() time.Time) Limiter {
	if db == nil { return NewRollingWindow(now) }
	if now == nil { now = time.Now }
	return &sqlWindow{db: db, now: now}
}

type sqlWindow struct { db *sql.DB; now func() time.Time }

func (l *sqlWindow) Allow(ctx context.Context, key Key, policy Policy) (Decision, error) {
	if err := ctx.Err(); err != nil { return Decision{}, err }
	if policy.Limit == 0 || policy.Limit > math.MaxInt64 { return Decision{}, ErrInvalidLimit }
	if policy.Window <= 0 { return Decision{}, ErrInvalidWindow }

	at := l.now().UTC()
	// A stable sentinel makes this one shared state row per hashed key. The
	// active window begins with the first accepted request and is reset
	// atomically after expiration rather than at a wall-clock boundary.
	bucketAt := time.Unix(1, 0).UTC()
	resetAt := at.Add(policy.Window)
	q := dbgen.New(l.db)
	updated, err := q.IncrementRateLimitBucket(ctx, incrementParams(rateLimitKeyHash(key), bucketAt, resetAt, at, policy.Limit))
	if err != nil { return Decision{}, fmt.Errorf("increment rate-limit bucket: %w", err) }

	bucket, err := q.GetRateLimitBucket(ctx, getParams(rateLimitKeyHash(key), bucketAt))
	if err != nil { return Decision{}, fmt.Errorf("read rate-limit bucket: %w", err) }
	hits := uint64(bucket.Hits)
	resetAt = bucket.ExpiresAt
	if updated == 0 { return Decision{Limit: policy.Limit, Remaining: 0, ResetAt: resetAt, RetryAt: resetAt}, nil }
	remaining := uint64(0)
	if hits < policy.Limit { remaining = policy.Limit - hits }
	return Decision{Allowed: true, Limit: policy.Limit, Remaining: remaining, ResetAt: resetAt}, nil
}

func rateLimitKeyHash(key Key) string {
	sum := sha256.Sum256([]byte(key.Scope + "\x00" + key.Subject + "\x00" + key.Operation))
	return fmt.Sprintf("%x", sum[:])
}

{{if eq .Database "postgres"}}
func incrementParams(key string, bucketAt, resetAt, now time.Time, limit uint64) dbgen.IncrementRateLimitBucketParams {
	return dbgen.IncrementRateLimitBucketParams{KeyHash: key, BucketAt: bucketAt, ExpiresAt: resetAt, Now: now, MaxHits: int64(limit)}
}
func getParams(key string, bucketAt time.Time) dbgen.GetRateLimitBucketParams {
	return dbgen.GetRateLimitBucketParams{KeyHash: key, BucketAt: bucketAt}
}
{{else}}
func incrementParams(key string, bucketAt, resetAt, now time.Time, limit uint64) dbgen.IncrementRateLimitBucketParams {
	return dbgen.IncrementRateLimitBucketParams{KeyHash: key, BucketAt: bucketAt, ExpiresAt: resetAt, Now: now, MaxHits: limit}
}
func getParams(key string, bucketAt time.Time) dbgen.GetRateLimitBucketParams {
	return dbgen.GetRateLimitBucketParams{KeyHash: key, BucketAt: bucketAt}
}
