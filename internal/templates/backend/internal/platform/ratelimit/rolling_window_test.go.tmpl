package ratelimit_test

import (
	"context"
	"sync"
	"sync/atomic"
	"testing"
	"time"

	"{{.Module}}/backend/internal/platform/ratelimit"
)

func TestRollingWindowEnforcesLimitResetsAndIsolatesTenantCapacity(t *testing.T) {
	now := time.Date(2026, time.July, 13, 12, 0, 0, 0, time.UTC)
	limiter := ratelimit.NewRollingWindow(func() time.Time { return now })
	policy := ratelimit.Policy{Limit: 2, Window: time.Minute}
	key := ratelimit.Key{Scope: "organization:one", Subject: "user:one", Operation: "posts:create"}

	first, err := limiter.Allow(context.Background(), key, policy)
	if err != nil {
		t.Fatal(err)
	}
	if !first.Allowed || first.Remaining != 1 {
		t.Fatalf("first decision = %#v", first)
	}
	second, err := limiter.Allow(context.Background(), key, policy)
	if err != nil {
		t.Fatal(err)
	}
	if !second.Allowed || second.Remaining != 0 {
		t.Fatalf("second decision = %#v", second)
	}
	rejected, err := limiter.Allow(context.Background(), key, policy)
	if err != nil {
		t.Fatal(err)
	}
	if rejected.Allowed || !rejected.ResetAt.Equal(now.Add(time.Minute)) || !rejected.RetryAt.Equal(rejected.ResetAt) {
		t.Fatalf("rejection = %#v", rejected)
	}

	otherTenant, err := limiter.Allow(context.Background(), ratelimit.Key{Scope: "organization:two", Subject: key.Subject, Operation: key.Operation}, policy)
	if err != nil {
		t.Fatal(err)
	}
	if !otherTenant.Allowed || otherTenant.Remaining != 1 {
		t.Fatalf("other tenant decision = %#v", otherTenant)
	}

	now = now.Add(time.Minute)
	reset, err := limiter.Allow(context.Background(), key, policy)
	if err != nil {
		t.Fatal(err)
	}
	if !reset.Allowed || reset.Remaining != 1 {
		t.Fatalf("reset decision = %#v", reset)
	}
}

func TestRollingWindowNeverAllowsMoreThanLimitConcurrently(t *testing.T) {
	limiter := ratelimit.NewRollingWindow(time.Now)
	policy := ratelimit.Policy{Limit: 10, Window: time.Minute}
	key := ratelimit.Key{Scope: "organization:one", Subject: "user:one", Operation: "posts:create"}
	var allowed atomic.Int64
	var group sync.WaitGroup
	for range 100 {
		group.Add(1)
		go func() {
			defer group.Done()
			decision, err := limiter.Allow(context.Background(), key, policy)
			if err != nil {
				t.Errorf("allow: %v", err)
				return
			}
			if decision.Allowed {
				allowed.Add(1)
			}
		}()
	}
	group.Wait()
	if allowed.Load() != int64(policy.Limit) {
		t.Fatalf("allowed = %d, want %d", allowed.Load(), policy.Limit)
	}
}

func TestSQLRollingWindowFallsBackSafelyWithoutDatabase(t *testing.T) {
	now := time.Date(2026, time.July, 14, 12, 0, 0, 0, time.UTC)
	limiter := ratelimit.NewSQLRollingWindow(nil, func() time.Time { return now })
	policy := ratelimit.Policy{Limit: 1, Window: time.Minute}
	first, err := limiter.Allow(context.Background(), ratelimit.Key{Scope: "organization:one", Subject: "user:one", Operation: "posts:create"}, policy)
	if err != nil || !first.Allowed { t.Fatalf("fallback first = %#v, %v", first, err) }
	second, err := limiter.Allow(context.Background(), ratelimit.Key{Scope: "organization:one", Subject: "user:one", Operation: "posts:create"}, policy)
	if err != nil || second.Allowed || !second.RetryAt.Equal(now.Add(time.Minute)) { t.Fatalf("fallback rejection = %#v, %v", second, err) }
}
