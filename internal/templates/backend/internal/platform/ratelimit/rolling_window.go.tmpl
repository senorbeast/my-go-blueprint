package ratelimit

import (
	"context"
	"errors"
	"sync"
	"time"
)

var (
	ErrInvalidLimit  = errors.New("rate limit must be greater than zero")
	ErrInvalidWindow = errors.New("rate limit window must be greater than zero")
)

// NewRollingWindow creates the safe in-process fallback for compositions that
// cannot open a database. Bootstrap uses NewSQLRollingWindow instead.
func NewRollingWindow(now func() time.Time) Limiter {
	if now == nil {
		now = time.Now
	}
	return &rollingWindow{now: now, hits: make(map[Key][]time.Time)}
}

type rollingWindow struct {
	mu   sync.Mutex
	now  func() time.Time
	hits map[Key][]time.Time
}

func (l *rollingWindow) Allow(ctx context.Context, key Key, policy Policy) (Decision, error) {
	if err := ctx.Err(); err != nil {
		return Decision{}, err
	}
	if policy.Limit == 0 {
		return Decision{}, ErrInvalidLimit
	}
	if policy.Window <= 0 {
		return Decision{}, ErrInvalidWindow
	}

	at := l.now().UTC()
	cutoff := at.Add(-policy.Window)
	l.mu.Lock()
	defer l.mu.Unlock()

	hits := l.hits[key]
	firstLive := 0
	for firstLive < len(hits) && !hits[firstLive].After(cutoff) {
		firstLive++
	}
	hits = hits[firstLive:]
	if uint64(len(hits)) >= policy.Limit {
		reset := hits[0].Add(policy.Window)
		l.hits[key] = hits
		return Decision{Limit: policy.Limit, Remaining: 0, ResetAt: reset, RetryAt: reset}, nil
	}

	hits = append(hits, at)
	l.hits[key] = hits
	return Decision{Allowed: true, Limit: policy.Limit, Remaining: policy.Limit - uint64(len(hits)), ResetAt: hits[0].Add(policy.Window)}, nil
}
