package auth

import (
	"context"
	"crypto/hmac"
	"crypto/sha256"
	"encoding/base64"
	"encoding/json"
	"errors"
	"fmt"
	"strings"
	"time"
)

// JWT issues and verifies short-lived, HMAC-signed access tokens. It keeps the
// token format at the platform boundary; domain and application code only see a Principal.
type JWT struct {
	secret []byte
	now    func() time.Time
}

type claims struct {
	Subject        string `json:"sub"`
	OrganizationID string `json:"org"`
	SessionID      string `json:"sid"`
	ExpiresAt      int64  `json:"exp"`
	IssuedAt       int64  `json:"iat"`
}

func NewJWT(secret string) (*JWT, error) {
	if len(secret) < 32 {
		return nil, errors.New("JWT secret must be at least 32 bytes")
	}
	return &JWT{secret: []byte(secret), now: time.Now}, nil
}

func (j *JWT) Issue(_ context.Context, principal Principal, expiresAt time.Time) (string, error) {
	if principal.UserID == "" || principal.OrganizationID == "" || principal.SessionID == "" {
		return "", errors.New("access token principal is incomplete")
	}
	header, err := json.Marshal(map[string]string{"alg": "HS256", "typ": "JWT"})
	if err != nil { return "", fmt.Errorf("marshal access token header: %w", err) }
	payload, err := json.Marshal(claims{Subject: string(principal.UserID), OrganizationID: string(principal.OrganizationID), SessionID: string(principal.SessionID), ExpiresAt: expiresAt.Unix(), IssuedAt: j.now().Unix()})
	if err != nil { return "", fmt.Errorf("marshal access token claims: %w", err) }
	signingInput := encode(header) + "." + encode(payload)
	return signingInput + "." + j.sign(signingInput), nil
}

func (j *JWT) Verify(_ context.Context, token string) (Principal, error) {
	parts := strings.Split(token, ".")
	if len(parts) != 3 || parts[0] == "" || parts[1] == "" || parts[2] == "" { return Principal{}, errors.New("malformed access token") }
	if !hmac.Equal([]byte(parts[2]), []byte(j.sign(parts[0]+"."+parts[1]))) { return Principal{}, errors.New("invalid access token signature") }
	headerBytes, err := decode(parts[0]); if err != nil { return Principal{}, errors.New("invalid access token header") }
	var header struct { Algorithm string `json:"alg"`; Type string `json:"typ"` }
	if err := json.Unmarshal(headerBytes, &header); err != nil || header.Algorithm != "HS256" || header.Type != "JWT" { return Principal{}, errors.New("invalid access token header") }
	payload, err := decode(parts[1]); if err != nil { return Principal{}, errors.New("invalid access token claims") }
	var parsed claims
	if err := json.Unmarshal(payload, &parsed); err != nil { return Principal{}, errors.New("invalid access token claims") }
	if parsed.Subject == "" || parsed.OrganizationID == "" || parsed.SessionID == "" || parsed.ExpiresAt <= j.now().Unix() { return Principal{}, errors.New("expired or incomplete access token") }
	return Principal{UserID: UserID(parsed.Subject), OrganizationID: OrganizationID(parsed.OrganizationID), SessionID: SessionID(parsed.SessionID)}, nil
}

func (j *JWT) sign(input string) string { mac := hmac.New(sha256.New, j.secret); _, _ = mac.Write([]byte(input)); return encode(mac.Sum(nil)) }
func encode(value []byte) string { return base64.RawURLEncoding.EncodeToString(value) }
func decode(value string) ([]byte, error) { return base64.RawURLEncoding.DecodeString(value) }

var _ interface { Issue(context.Context, Principal, time.Time) (string, error); Verify(context.Context, string) (Principal, error) } = (*JWT)(nil)
