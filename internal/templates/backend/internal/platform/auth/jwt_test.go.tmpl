package auth

import (
	"context"
	"strings"
	"testing"
	"time"
)

func TestJWTIssuesAndVerifiesPrincipal(t *testing.T) {
	issuer, err := NewJWT(strings.Repeat("a", 32)); if err != nil { t.Fatal(err) }
	issuer.now = func() time.Time { return time.Unix(100, 0) }
	token, err := issuer.Issue(context.Background(), Principal{UserID: "user", OrganizationID: "org", SessionID: "session"}, time.Unix(200, 0)); if err != nil { t.Fatal(err) }
	principal, err := issuer.Verify(context.Background(), token); if err != nil { t.Fatal(err) }
	if principal.UserID != "user" || principal.OrganizationID != "org" || principal.SessionID != "session" { t.Fatalf("principal = %#v", principal) }
}

func TestJWTRejectsExpiredAndTamperedTokens(t *testing.T) {
	issuer, err := NewJWT(strings.Repeat("a", 32)); if err != nil { t.Fatal(err) }
	issuer.now = func() time.Time { return time.Unix(100, 0) }
	token, err := issuer.Issue(context.Background(), Principal{UserID: "user", OrganizationID: "org", SessionID: "session"}, time.Unix(100, 0)); if err != nil { t.Fatal(err) }
	if _, err := issuer.Verify(context.Background(), token); err == nil { t.Fatal("expired token was accepted") }
	if _, err := issuer.Verify(context.Background(), token+"x"); err == nil { t.Fatal("tampered token was accepted") }
}
