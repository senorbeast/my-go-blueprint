package jobs

import (
	"context"
	"errors"
	"testing"
	"time"
)

type failingHandler struct{ calls int }
func (h *failingHandler) Handle(context.Context, Job) error { h.calls++; return errors.New("temporary failure") }
type successfulHandler struct{ calls int }
func (h *successfulHandler) Handle(context.Context, Job) error { h.calls++; return nil }

// TestWorkerClaimLeaseRetryIdempotencyAndRestartRecovery exercises the worker
// boundary: duplicates coalesce, failures retry, and an expired lease can be
// recovered by a replacement worker.
func TestWorkerClaimLeaseRetryIdempotencyAndRestartRecovery(t *testing.T) {
	ctx := context.Background(); store := NewMemoryStore(); registry := NewRegistry()
	failing := &failingHandler{}; if err := registry.Register("email", failing); err != nil { t.Fatal(err) }
	id, err := store.Enqueue(ctx, Job{Name: "email", MaxAttempts: 2, IdempotencyKey: "welcome:42"}); if err != nil { t.Fatal(err) }
	duplicate, err := store.Enqueue(ctx, Job{Name: "email", MaxAttempts: 2, IdempotencyKey: "welcome:42"}); if err != nil || duplicate != id { t.Fatalf("duplicate = %q, %v; want %q, nil", duplicate, err, id) }
	worker := NewWorker(store, registry, time.Minute)
	if ran, err := worker.RunOnce(ctx); !ran || err != nil { t.Fatalf("first attempt = %v, %v", ran, err) }
	if ran, err := worker.RunOnce(ctx); !ran || err != nil { t.Fatalf("retry = %v, %v", ran, err) }
	if failing.calls != 2 { t.Fatalf("calls = %d, want 2", failing.calls) }
	if ran, err := worker.RunOnce(ctx); ran || err != nil { t.Fatalf("dead letter must not run: %v, %v", ran, err) }

	recoveredID, err := store.Enqueue(ctx, Job{Name: "recovery", MaxAttempts: 2}); if err != nil { t.Fatal(err) }
	claimed, ok, err := store.Claim(ctx, time.Now(), time.Millisecond); if err != nil || !ok || claimed.ID != recoveredID { t.Fatalf("initial claim = %#v, %v, %v", claimed, ok, err) }
	success := &successfulHandler{}; if err := registry.Register("recovery", success); err != nil { t.Fatal(err) }
	replacement := NewWorker(store, registry, time.Minute); replacement.now = func() time.Time { return claimed.LeaseUntil.Add(time.Nanosecond) }
	if ran, err := replacement.RunOnce(ctx); !ran || err != nil { t.Fatalf("restart recovery = %v, %v", ran, err) }
	if success.calls != 1 { t.Fatalf("recovered calls = %d, want 1", success.calls) }
}
