package jobs

import (
	"context"
	"testing"
	"time"
)

func TestDemoHeartbeatCanBeEnqueuedAndHandled(t *testing.T) {
	at := time.Date(2026, time.July, 19, 12, 34, 56, 0, time.FixedZone("IST", 5*60*60+30*60))
	job := NewDemoHeartbeat(at)
	if job.Name != DemoHeartbeatName || job.MaxAttempts != 3 {
		t.Fatalf("job = %#v", job)
	}
	if job.IdempotencyKey != "demo-heartbeat:2026-07-19T07:04:00Z" {
		t.Fatalf("idempotency key = %q", job.IdempotencyKey)
	}
	if err := NewDemoHeartbeatHandler(nil).Handle(context.Background(), job); err != nil {
		t.Fatalf("Handle() error = %v", err)
	}
}

func TestDemoHeartbeatHandlerRejectsInvalidPayload(t *testing.T) {
	err := NewDemoHeartbeatHandler(nil).Handle(context.Background(), Job{Payload: []byte(`{}`)})
	if err == nil {
		t.Fatal("Handle() error = nil, want malformed payload error")
	}
}
