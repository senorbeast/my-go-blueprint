package application

import (
	"context"

	organizations "{{.Module}}/backend/internal/features/organizations/application"
	users "{{.Module}}/backend/internal/features/users/application"
	platformauth "{{.Module}}/backend/internal/platform/auth"
)

// Credentials coordinates the narrow credential-to-session flow. Persistence
// and token issuance remain owned by their respective feature applications.
type Credentials struct {
	users         *users.Service
	organizations *organizations.Service
	sessions      *Service
	passwords     users.PasswordHasher
}

func NewCredentials(usersService *users.Service, organizationsService *organizations.Service, sessionService *Service, passwords users.PasswordHasher) *Credentials {
	return &Credentials{users: usersService, organizations: organizationsService, sessions: sessionService, passwords: passwords}
}

type Signup struct { Email, DisplayName, Password, OrganizationName string }
type Login struct { Email, Password string }

func (s *Credentials) Signup(ctx context.Context, command Signup) (Tokens, error) {
	user, err := s.users.Signup(ctx, users.Signup{Email: command.Email, DisplayName: command.DisplayName, Password: command.Password}, s.passwords)
	if err != nil { return Tokens{}, err }
	organization, err := s.organizations.Create(ctx, platformauth.Principal{UserID: platformauth.UserID(user.ID)}, command.OrganizationName)
	if err != nil { return Tokens{}, err }
	return s.sessions.Start(ctx, platformauth.UserID(user.ID), organization.ID)
}

func (s *Credentials) Login(ctx context.Context, command Login) (Tokens, error) {
	user, err := s.users.Authenticate(ctx, command.Email, command.Password, s.passwords)
	if err != nil { return Tokens{}, err }
	organization, err := s.organizations.DefaultOrganization(ctx, platformauth.UserID(user.ID))
	if err != nil { return Tokens{}, err }
	return s.sessions.Start(ctx, platformauth.UserID(user.ID), organization.ID)
}
