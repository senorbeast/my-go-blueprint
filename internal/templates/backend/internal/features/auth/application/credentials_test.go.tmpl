func TestCredentialsSignupCreatesOrganizationAndSession(t *testing.T) {
	clock := fixedClock{now: time.Unix(100, 0)}
	ids := fixedIDs{}
	userRepository := &credentialUserRepository{}
	organizationRepository := &credentialOrganizationRepository{}
	userService := users.New(userRepository, nil, ids, clock)
	organizationService := organizations.New(organizationRepository, nil, clock, ids)
	sessionService := New(&reuseRepository{}, clock, fixedSecrets{}, ids, credentialIssuer{}, time.Minute, time.Hour)
	service := NewCredentials(userService, organizationService, sessionService, credentialPasswords{})

	tokens, err := service.Signup(context.Background(), Signup{Email: "owner@example.com", DisplayName: "Owner", Password: "secret", OrganizationName: "Acme"})
	if err != nil { t.Fatalf("Signup() error = %v", err) }
	if userRepository.user.Email != "owner@example.com" { t.Fatalf("user email = %q", userRepository.user.Email) }
	if organizationRepository.organization.Name != "Acme" { t.Fatalf("organization name = %q", organizationRepository.organization.Name) }
	if organizationRepository.role.Name != "owner" || organizationRepository.permission.Name != "platform.admin" { t.Fatalf("owner grant = %#v / %#v", organizationRepository.role, organizationRepository.permission) }
	if tokens.AccessToken != "access-for-id" { t.Fatalf("access token = %q", tokens.AccessToken) }
}
