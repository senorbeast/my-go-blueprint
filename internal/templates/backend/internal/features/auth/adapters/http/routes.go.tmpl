package http

import (
	"context"

	"github.com/danielgtaylor/huma/v2"
	"{{.Module}}/backend/internal/features/auth/application"
	platformauth "{{.Module}}/backend/internal/platform/auth"
	platformerrors "{{.Module}}/backend/internal/platform/errors"
	httpplatform "{{.Module}}/backend/internal/platform/http"
)

type SessionCookiePolicy interface {
	SessionCookies(application.Tokens) []string
	ClearSessionCookies() []string
}
type SessionService interface {
	Rotate(context.Context, string) (application.Tokens, error)
	Logout(context.Context, platformauth.Principal) error
}
type CredentialService interface {
	Signup(context.Context, application.Signup) (application.Tokens, error)
	Login(context.Context, application.Login) (application.Tokens, error)
}
type CurrentSessionService interface { Current(context.Context, platformauth.Principal) (application.SessionContext, error) }
type Routes struct {
	service SessionService
	credentials CredentialService
	current CurrentSessionService
	cookies SessionCookiePolicy
}

func New(service SessionService, credentials CredentialService, current CurrentSessionService, cookies SessionCookiePolicy) Routes {
	return Routes{service: service, credentials: credentials, current: current, cookies: cookies}
}
func (Routes) Descriptor() httpplatform.Descriptor {
	return httpplatform.Descriptor{Prefix: "/api/v1/auth", Tags: []string{"Authentication"}, Authentication: httpplatform.Optional}
}
func (r Routes) Register(reg httpplatform.Registrar) error {
	httpplatform.Register(reg, huma.Operation{OperationID: "current-session", Method: "GET", Path: "/api/v1/auth/me", Tags: []string{"Authentication"}}, func(ctx context.Context, _ *CurrentSessionInput) (*CurrentSessionOutput, error) { principal, ok := platformauth.PrincipalFrom(ctx); if !ok { return nil, platformerrors.New(platformerrors.Unauthenticated, "authentication_required", "Authentication is required") }; current, err := r.current.Current(ctx, principal); if err != nil { return nil, err }; organizations := make([]SessionOrganizationBody, len(current.Organizations)); for i, organization := range current.Organizations { organizations[i] = SessionOrganizationBody{ID: organization.ID, Name: organization.Name} }; return &CurrentSessionOutput{Body: CurrentSessionBody{ID: current.UserID, Email: current.Email, DisplayName: current.DisplayName, OrganizationID: current.OrganizationID, Organizations: organizations, Permissions: current.Permissions}}, nil })
	httpplatform.Register(reg, huma.Operation{OperationID: "signup", Method: "POST", Path: "/api/v1/auth/signup", Tags: []string{"Authentication"}}, func(ctx context.Context, in *SignupInput) (*SessionOutput, error) {
		tokens, err := r.credentials.Signup(ctx, application.Signup{Email: in.Body.Email, DisplayName: in.Body.DisplayName, Password: in.Body.Password, OrganizationName: in.Body.OrganizationName})
		if err != nil { return nil, err }
		return r.sessionOutput(tokens), nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "login", Method: "POST", Path: "/api/v1/auth/login", Tags: []string{"Authentication"}}, func(ctx context.Context, in *LoginInput) (*SessionOutput, error) {
		tokens, err := r.credentials.Login(ctx, application.Login{Email: in.Body.Email, Password: in.Body.Password})
		if err != nil { return nil, err }
		return r.sessionOutput(tokens), nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "refresh-session", Method: "POST", Path: "/api/v1/auth/refresh", Tags: []string{"Authentication"}}, func(ctx context.Context, in *RefreshInput) (*RefreshOutput, error) {
		tokens, err := r.service.Rotate(ctx, in.RefreshToken)
		if err != nil {
			return nil, err
		}
		return r.sessionOutput(tokens), nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "logout-session", Method: "POST", Path: "/api/v1/auth/logout", Tags: []string{"Authentication"}}, func(ctx context.Context, _ *LogoutInput) (*LogoutOutput, error) {
		principal, ok := platformauth.PrincipalFrom(ctx)
		if ok {
			if err := r.service.Logout(ctx, principal); err != nil {
				return nil, err
			}
		}
		return &LogoutOutput{SetCookie: r.cookies.ClearSessionCookies()}, nil
	})
	return nil
}

func (r Routes) sessionOutput(tokens application.Tokens) *SessionOutput {
	out := &SessionOutput{SetCookie: r.cookies.SessionCookies(tokens)}
	out.Body.AccessExpiresAt = tokens.AccessExpiry
	out.Body.RefreshExpiresAt = tokens.RefreshExpiry
	return out
}
