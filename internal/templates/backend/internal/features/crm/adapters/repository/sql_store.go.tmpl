func organizationValue(value domain.OrganizationID) (uuid.UUID, error) { return uuid.Parse(string(value)) }
func listCompanies(ctx context.Context, q *dbgen.Queries, query domain.ListQuery) ([]dbgen.CrmCompany, error) { organization, err := organizationValue(query.OrganizationID); if err != nil { return nil, err }; return q.ListCRMCompanies(ctx, dbgen.ListCRMCompaniesParams{OrganizationID: organization, Limit: int32(query.Page.Limit) + 1}) }
