func requireLimit(query domain.ListQuery) error { if query.Page.Limit == 0 { return fmt.Errorf("CRM list limit is required") }; return nil }
func companyPage(items []domain.Company, limit pagination.Limit) pagination.Page[domain.Company] { page := pagination.Page[domain.Company]{Items: items}; if len(page.Items) > int(limit) { page.HasMore = true; page.Items = page.Items[:limit] }; return page }
func contactPage(items []domain.Contact, limit pagination.Limit) pagination.Page[domain.Contact] { page := pagination.Page[domain.Contact]{Items: items}; if len(page.Items) > int(limit) { page.HasMore = true; page.Items = page.Items[:limit] }; return page }
