// SQLStore is the CRM read adapter. Its statements live exclusively in the
// sqlc catalog; this layer only translates generated records at the dialect
// boundary and preserves tenant scope supplied by the application service.
type SQLStore struct{ db *sql.DB }
func NewSQLStore(db *sql.DB) *SQLStore { return &SQLStore{db: db} }

func (s *SQLStore) ListCompanies(ctx context.Context, query domain.ListQuery) (pagination.Page[domain.Company], error) {
	if err := requireLimit(query); err != nil { return pagination.Page[domain.Company]{}, err }
	rows, err := listCompanies(ctx, dbgen.New(s.db), query); if err != nil { return pagination.Page[domain.Company]{}, fmt.Errorf("list CRM companies: %w", err) }
	items := make([]domain.Company, 0, len(rows)); for _, row := range rows { items = append(items, companyFrom(row)) }; return companyPage(items, query.Page.Limit), nil
}
func (s *SQLStore) ListContacts(ctx context.Context, query domain.ListQuery) (pagination.Page[domain.Contact], error) {
	if err := requireLimit(query); err != nil { return pagination.Page[domain.Contact]{}, err }
	rows, err := listContacts(ctx, dbgen.New(s.db), query); if err != nil { return pagination.Page[domain.Contact]{}, fmt.Errorf("list CRM contacts: %w", err) }
	items := make([]domain.Contact, 0, len(rows)); for _, row := range rows { item, err := contactFrom(row); if err != nil { return pagination.Page[domain.Contact]{}, err }; items = append(items, item) }; return contactPage(items, query.Page.Limit), nil
}
