func companyFrom(row dbgen.CrmCompany) domain.Company { return domain.Company{ID: domain.ID(row.ID.String()), OrganizationID: domain.OrganizationID(row.OrganizationID.String()), Name: row.Name, CreatedAt: row.CreatedAt} }
func contactFrom(row dbgen.CrmContact) (domain.Contact, error) { item := domain.Contact{ID: domain.ID(row.ID.String()), OrganizationID: domain.OrganizationID(row.OrganizationID.String()), Name: row.Name, Email: row.Email, CreatedAt: row.CreatedAt}; if row.CompanyID.Valid { value := domain.ID(row.CompanyID.UUID.String()); item.CompanyID = &value }; return item, nil }
func pipelineFrom(row dbgen.CrmPipeline) domain.Pipeline { return domain.Pipeline{ID: domain.ID(row.ID.String()), OrganizationID: domain.OrganizationID(row.OrganizationID.String()), Name: row.Name, CreatedAt: row.CreatedAt} }
func stageFrom(row dbgen.CrmStage) (domain.Stage, error) { return domain.Stage{ID: domain.ID(row.ID.String()), OrganizationID: domain.OrganizationID(row.OrganizationID.String()), PipelineID: domain.ID(row.PipelineID.String()), Name: row.Name, Position: int(row.Position), CreatedAt: row.CreatedAt}, nil }
func dealFrom(row dbgen.CrmDeal) (domain.Deal, error) { return domain.Deal{ID: domain.ID(row.ID.String()), OrganizationID: domain.OrganizationID(row.OrganizationID.String()), CompanyID: domain.ID(row.CompanyID.String()), PipelineID: domain.ID(row.PipelineID.String()), StageID: domain.ID(row.StageID.String()), Name: row.Name, ValueCents: row.ValueCents, CreatedAt: row.CreatedAt}, nil }
func activityFrom(row dbgen.CrmActivity) (domain.Activity, error) { return domain.Activity{ID: domain.ID(row.ID.String()), OrganizationID: domain.OrganizationID(row.OrganizationID.String()), DealID: domain.ID(row.DealID.String()), Kind: row.Kind, Note: row.Note, OccurredAt: row.OccurredAt, CreatedAt: row.CreatedAt}, nil }
{{else}}
func idValue(value string) ([]byte, error) { compact := strings.ReplaceAll(value, "-", ""); if len(compact) != 32 { return nil, fmt.Errorf("invalid UUID %q", value) }; return hex.DecodeString(compact) }
func stringID(value []byte) (string, error) { if len(value) != 16 { return "", fmt.Errorf("unexpected UUID byte length %d", len(value)) }; encoded := hex.EncodeToString(value); return encoded[0:8]+"-"+encoded[8:12]+"-"+encoded[12:16]+"-"+encoded[16:20]+"-"+encoded[20:32], nil }
func organizationValue(value domain.OrganizationID) ([]byte, error) { return idValue(string(value)) }
