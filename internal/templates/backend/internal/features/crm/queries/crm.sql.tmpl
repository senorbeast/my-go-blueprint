-- name: ListCRMCompanies :many
SELECT id, organization_id, name, created_at FROM crm_companies
WHERE organization_id = sqlc.arg(organization_id) AND (name > sqlc.arg(after_name) OR (name = sqlc.arg(after_name) AND id > sqlc.arg(after_id))) ORDER BY name, id LIMIT sqlc.arg(page_limit);
-- name: ListCRMContacts :many
SELECT id, organization_id, company_id, name, email, created_at FROM crm_contacts
WHERE organization_id = sqlc.arg(organization_id) AND (name > sqlc.arg(after_name) OR (name = sqlc.arg(after_name) AND id > sqlc.arg(after_id))) ORDER BY name, id LIMIT sqlc.arg(page_limit);
-- name: ListCRMPipelines :many
SELECT id, organization_id, name, created_at FROM crm_pipelines WHERE organization_id = sqlc.arg(organization_id) ORDER BY name, id LIMIT sqlc.arg(page_limit);
-- name: ListCRMStages :many
SELECT id, organization_id, pipeline_id, name, position, created_at FROM crm_stages WHERE organization_id = sqlc.arg(organization_id) ORDER BY position, id LIMIT sqlc.arg(page_limit);
-- name: ListCRMDeals :many
SELECT id, organization_id, company_id, pipeline_id, stage_id, name, value_cents, created_at FROM crm_deals WHERE organization_id = sqlc.arg(organization_id) ORDER BY created_at, id LIMIT sqlc.arg(page_limit);
-- name: ListCRMActivities :many
SELECT id, organization_id, deal_id, kind, note, occurred_at, created_at FROM crm_activities WHERE organization_id = sqlc.arg(organization_id) ORDER BY occurred_at, id LIMIT sqlc.arg(page_limit);
