package domain

import (
	"errors"
	"strings"
	"time"
)

type ID string
type OrganizationID string
type EntityKind string

const (
	Companies EntityKind = "companies"
	Contacts EntityKind = "contacts"
	Pipelines EntityKind = "pipelines"
	Stages EntityKind = "stages"
	Deals EntityKind = "deals"
	Activities EntityKind = "activities"
)

type Company struct { ID ID `json:"id"`; OrganizationID OrganizationID `json:"organizationId"`; Name string `json:"name"`; CreatedAt time.Time `json:"createdAt"` }
type Contact struct { ID ID `json:"id"`; OrganizationID OrganizationID `json:"organizationId"`; CompanyID *ID `json:"companyId,omitempty"`; Name string `json:"name"`; Email string `json:"email"`; CreatedAt time.Time `json:"createdAt"` }
type Pipeline struct { ID ID `json:"id"`; OrganizationID OrganizationID `json:"organizationId"`; Name string `json:"name"`; CreatedAt time.Time `json:"createdAt"` }
type Stage struct { ID ID `json:"id"`; OrganizationID OrganizationID `json:"organizationId"`; PipelineID ID `json:"pipelineId"`; Name string `json:"name"`; Position int `json:"position"`; CreatedAt time.Time `json:"createdAt"` }
type Deal struct { ID ID `json:"id"`; OrganizationID OrganizationID `json:"organizationId"`; CompanyID ID `json:"companyId"`; PipelineID ID `json:"pipelineId"`; StageID ID `json:"stageId"`; Name string `json:"name"`; ValueCents int64 `json:"valueCents"`; CreatedAt time.Time `json:"createdAt"` }
type Activity struct { ID ID `json:"id"`; OrganizationID OrganizationID `json:"organizationId"`; DealID ID `json:"dealId"`; Kind string `json:"kind"`; Note string `json:"note"`; OccurredAt time.Time `json:"occurredAt"`; CreatedAt time.Time `json:"createdAt"` }

var ErrNotFound = errors.New("CRM resource not found")

func NewID(value string) (ID, error) { value = strings.TrimSpace(value); if value == "" { return "", errors.New("id is required") }; return ID(value), nil }
func ValidateName(value string) (string, error) { value = strings.TrimSpace(value); if value == "" { return "", errors.New("name is required") }; if len(value) > 200 { return "", errors.New("name is too long") }; return value, nil }
func ValidateEmail(value string) (string, error) { value = strings.TrimSpace(value); if len(value) > 320 { return "", errors.New("email is too long") }; return value, nil }
func NormalizeNote(value string) string { return strings.TrimSpace(value) }
