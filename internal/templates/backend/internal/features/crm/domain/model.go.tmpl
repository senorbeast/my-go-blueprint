package domain

import (
	"errors"
	"strings"
	"time"
)

type ID string
type OrganizationID string
type EntityKind string

const (
	Companies EntityKind = "companies"
	Contacts EntityKind = "contacts"
	Pipelines EntityKind = "pipelines"
	Stages EntityKind = "stages"
	Deals EntityKind = "deals"
	Activities EntityKind = "activities"
)

type Company struct { ID ID; OrganizationID OrganizationID; Name string; CreatedAt time.Time }
type Contact struct { ID ID; OrganizationID OrganizationID; CompanyID *ID; Name, Email string; CreatedAt time.Time }
type Pipeline struct { ID ID; OrganizationID OrganizationID; Name string; CreatedAt time.Time }
type Stage struct { ID ID; OrganizationID OrganizationID; PipelineID ID; Name string; Position int; CreatedAt time.Time }
type Deal struct { ID ID; OrganizationID OrganizationID; CompanyID, PipelineID, StageID ID; Name string; ValueCents int64; CreatedAt time.Time }
type Activity struct { ID ID; OrganizationID OrganizationID; DealID ID; Kind, Note string; OccurredAt, CreatedAt time.Time }

var ErrNotFound = errors.New("CRM resource not found")

func NewID(value string) (ID, error) { value = strings.TrimSpace(value); if value == "" { return "", errors.New("id is required") }; return ID(value), nil }
func ValidateName(value string) (string, error) { value = strings.TrimSpace(value); if value == "" { return "", errors.New("name is required") }; if len(value) > 200 { return "", errors.New("name is too long") }; return value, nil }
func ValidateEmail(value string) (string, error) { value = strings.TrimSpace(value); if len(value) > 320 { return "", errors.New("email is too long") }; return value, nil }
func NormalizeNote(value string) string { return strings.TrimSpace(value) }
