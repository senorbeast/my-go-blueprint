func (s *Service) CreateContact(ctx context.Context, principal auth.Principal, organizationID string, cmd CreateContact) (domain.Contact, error) {
	if err := s.authz.Authorize(ctx, principal, authorization.Permission("crm.contacts.create"), authorization.Resource{Kind: string(domain.Contacts), OrganizationID: auth.OrganizationID(organizationID)}); err != nil { return domain.Contact{}, err }
