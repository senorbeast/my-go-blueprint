package application

import (
	"context"
	"errors"
	"fmt"
	"time"
	"{{.Module}}/backend/internal/features/crm/domain"
	"{{.Module}}/backend/internal/platform/auth"
	"{{.Module}}/backend/internal/platform/authorization"
	platformerrors "{{.Module}}/backend/internal/platform/errors"
	"{{.Module}}/backend/internal/platform/pagination"
)

type IDGenerator interface { New() string }
type Clock interface { Now() time.Time }
type Service struct { repo domain.Repository; authz authorization.Authorizer; ids IDGenerator; clock Clock }
func New(repo domain.Repository, authz authorization.Authorizer, ids IDGenerator, clock Clock) *Service { return &Service{repo: repo, authz: authz, ids: ids, clock: clock} }

type CreateCompany struct { Name string }
func (s *Service) CreateCompany(ctx context.Context, principal auth.Principal, organizationID string, cmd CreateCompany) (domain.Company, error) {
	if err := s.authz.Authorize(ctx, principal, authorization.Permission("crm.companies.create"), authorization.Resource{Kind: string(domain.Companies), OrganizationID: auth.OrganizationID(organizationID)}); err != nil { return domain.Company{}, err }
	name, err := domain.ValidateName(cmd.Name); if err != nil { return domain.Company{}, err }
	company := domain.Company{ID: domain.ID(s.ids.New()), OrganizationID: domain.OrganizationID(organizationID), Name: name, CreatedAt: s.clock.Now()}
	if err := s.repo.CreateCompany(ctx, company); err != nil { return domain.Company{}, err }
	return company, nil
}

type UpdateCompany struct { Name string }
func (s *Service) UpdateCompany(ctx context.Context, principal auth.Principal, organizationID, companyID string, cmd UpdateCompany) (domain.Company, error) {
	if err := s.authz.Authorize(ctx, principal, authorization.Permission("crm.companies.update"), authorization.Resource{Kind: string(domain.Companies), OrganizationID: auth.OrganizationID(organizationID)}); err != nil { return domain.Company{}, err }
	id, err := domain.NewID(companyID); if err != nil { return domain.Company{}, err }
	name, err := domain.ValidateName(cmd.Name); if err != nil { return domain.Company{}, err }
	company, err := s.repo.FindCompany(ctx, domain.OrganizationID(organizationID), id)
	if errors.Is(err, domain.ErrNotFound) { return domain.Company{}, platformerrors.New(platformerrors.NotFound, "crm_company_not_found", "CRM company was not found") }
	if err != nil { return domain.Company{}, err }
	company.Name = name
	if err := s.repo.UpdateCompany(ctx, company); err != nil { return domain.Company{}, err }
	return company, nil
}

