type CreatePipeline struct { Name string }
func (s *Service) CreatePipeline(ctx context.Context, principal auth.Principal, organizationID string, cmd CreatePipeline) (domain.Pipeline, error) {
	if err := s.authz.Authorize(ctx, principal, authorization.Permission("crm.pipelines.create"), authorization.Resource{Kind: string(domain.Pipelines), OrganizationID: auth.OrganizationID(organizationID)}); err != nil { return domain.Pipeline{}, err }
	name, err := domain.ValidateName(cmd.Name); if err != nil { return domain.Pipeline{}, err }
