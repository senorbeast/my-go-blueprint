func TestCRMListAuthorizesTenantAndPermission(t *testing.T) {
	ctx := context.Background()
	principal := auth.Principal{UserID: "owner", OrganizationID: "tenant-a"}
	repo := &crmRepository{}
	service := New(repo, organizationauthorization.New(&crmPermissions{permissions: []authorization.Permission{"platform.admin"}}), crmIDs{}, crmClock{})
	if _, err := service.List(ctx, principal, "tenant-a", domain.Companies, pagination.Request{Limit: 20}); err != nil { t.Fatalf("owner list = %v", err) }
	if !repo.listed || repo.query.OrganizationID != "tenant-a" { t.Fatalf("owner query = %+v, listed=%v", repo.query, repo.listed) }

	_, err := service.List(ctx, principal, "tenant-b", domain.Companies, pagination.Request{Limit: 20})
	var applicationError *platformerrors.Error
	if !errors.As(err, &applicationError) || applicationError.Kind != platformerrors.Forbidden { t.Fatalf("cross-tenant error = %v", err) }

	denied := New(&crmRepository{}, organizationauthorization.New(&crmPermissions{}), crmIDs{}, crmClock{})
	_, err = denied.List(ctx, principal, "tenant-a", domain.Companies, pagination.Request{Limit: 20})
	if !errors.As(err, &applicationError) || applicationError.Kind != platformerrors.Forbidden { t.Fatalf("unprivileged member error = %v", err) }
}

func TestFindCompanyAuthorizesTenantAndReturnsNotFound(t *testing.T) {
	ctx := context.Background()
	principal := auth.Principal{UserID: "owner", OrganizationID: "tenant-a"}
	companyID := domain.ID("00000000-0000-0000-0000-000000000051")
	company := domain.Company{ID: companyID, OrganizationID: "tenant-a", Name: "Acme"}
	service := New(&crmRepository{company: company}, organizationauthorization.New(&crmPermissions{permissions: []authorization.Permission{"platform.admin"}}), crmIDs{}, crmClock{})

	got, err := service.FindCompany(ctx, principal, "tenant-a", string(companyID))
	if err != nil || got != company { t.Fatalf("owner find = %+v, %v", got, err) }
	if _, err = service.FindCompany(ctx, principal, "tenant-b", string(companyID)); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("cross-tenant error = %v", err) }
	denied := New(&crmRepository{company: company}, organizationauthorization.New(&crmPermissions{}), crmIDs{}, crmClock{})
	if _, err = denied.FindCompany(ctx, principal, "tenant-a", string(companyID)); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("unprivileged member error = %v", err) }
	_, err = service.FindCompany(ctx, principal, "tenant-a", "00000000-0000-0000-0000-000000000099")
	var applicationError *platformerrors.Error
	if !errors.As(err, &applicationError) || applicationError.Kind != platformerrors.NotFound { t.Fatalf("unknown company error = %v", err) }
}

func TestUpdateCompanyAuthorizesTenantAndValidatesInput(t *testing.T) {
	ctx := context.Background()
	principal := auth.Principal{UserID: "owner", OrganizationID: "tenant-a"}
	companyID := domain.ID("00000000-0000-0000-0000-000000000051")
	repo := &crmRepository{company: domain.Company{ID: companyID, OrganizationID: "tenant-a", Name: "Acme"}}
	service := New(repo, organizationauthorization.New(&crmPermissions{permissions: []authorization.Permission{"platform.admin"}}), crmIDs{}, crmClock{})

	company, err := service.UpdateCompany(ctx, principal, "tenant-a", string(companyID), UpdateCompany{Name: "  Acme Renamed  "})
	if err != nil { t.Fatalf("update company = %v", err) }
	if !repo.companyUpdated || repo.company != company || company.Name != "Acme Renamed" { t.Fatalf("updated company = %+v, stored = %+v", company, repo.company) }
	if _, err = service.UpdateCompany(ctx, principal, "tenant-b", string(companyID), UpdateCompany{Name: "Acme"}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("cross-tenant error = %v", err) }
	denied := New(&crmRepository{company: repo.company}, organizationauthorization.New(&crmPermissions{}), crmIDs{}, crmClock{})
	if _, err = denied.UpdateCompany(ctx, principal, "tenant-a", string(companyID), UpdateCompany{Name: "Acme"}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("unprivileged member error = %v", err) }
	if _, err = service.UpdateCompany(ctx, principal, "tenant-a", string(companyID), UpdateCompany{Name: " "}); err == nil { t.Fatal("blank company name accepted") }
	_, err = service.UpdateCompany(ctx, principal, "tenant-a", "00000000-0000-0000-0000-000000000099", UpdateCompany{Name: "Acme"})
	var applicationError *platformerrors.Error
	if !errors.As(err, &applicationError) || applicationError.Kind != platformerrors.NotFound { t.Fatalf("unknown company error = %v", err) }
}

