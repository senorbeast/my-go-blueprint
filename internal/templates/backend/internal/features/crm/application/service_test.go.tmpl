type crmRepository struct { query domain.ListQuery; listed bool; company domain.Company; contact domain.Contact; pipeline domain.Pipeline; stage domain.Stage; deal domain.Deal; activity domain.Activity; created bool; companyUpdated bool; contactCreated bool; pipelineCreated bool; stageCreated bool; dealCreated bool; activityCreated bool }
func (r *crmRepository) CreateCompany(_ context.Context, company domain.Company) error { r.company = company; r.created = true; return nil }
func (r *crmRepository) UpdateCompany(_ context.Context, company domain.Company) error { r.company = company; r.companyUpdated = true; return nil }
func (r *crmRepository) CreateContact(_ context.Context, contact domain.Contact) error { r.contact = contact; r.contactCreated = true; return nil }
func (r *crmRepository) CreatePipeline(_ context.Context, pipeline domain.Pipeline) error { r.pipeline = pipeline; r.pipelineCreated = true; return nil }
func (r *crmRepository) CreateStage(_ context.Context, stage domain.Stage) error { r.stage = stage; r.stageCreated = true; return nil }
func (r *crmRepository) CreateDeal(_ context.Context, deal domain.Deal) error { r.deal = deal; r.dealCreated = true; return nil }
func (r *crmRepository) CreateActivity(_ context.Context, activity domain.Activity) error { r.activity = activity; r.activityCreated = true; return nil }
func (r *crmRepository) FindCompany(_ context.Context, organizationID domain.OrganizationID, companyID domain.ID) (domain.Company, error) { if r.company.ID == companyID && r.company.OrganizationID == organizationID { return r.company, nil }; return domain.Company{}, domain.ErrNotFound }
func (*crmRepository) FindContact(context.Context, domain.OrganizationID, domain.ID) (domain.Contact, error) { return domain.Contact{}, nil }
func (r *crmRepository) FindPipeline(_ context.Context, organizationID domain.OrganizationID, pipelineID domain.ID) (domain.Pipeline, error) { if r.pipeline.ID == pipelineID && r.pipeline.OrganizationID == organizationID { return r.pipeline, nil }; return domain.Pipeline{}, errors.New("pipeline not found") }
func (r *crmRepository) FindStage(_ context.Context, organizationID domain.OrganizationID, stageID domain.ID) (domain.Stage, error) { if r.stage.ID == stageID && r.stage.OrganizationID == organizationID { return r.stage, nil }; return domain.Stage{}, errors.New("stage not found") }
func (r *crmRepository) FindDeal(_ context.Context, organizationID domain.OrganizationID, dealID domain.ID) (domain.Deal, error) { if r.deal.ID == dealID && r.deal.OrganizationID == organizationID { return r.deal, nil }; return domain.Deal{}, errors.New("deal not found") }
func (*crmRepository) FindActivity(context.Context, domain.OrganizationID, domain.ID) (domain.Activity, error) { return domain.Activity{}, nil }
func (r *crmRepository) ListCompanies(_ context.Context, query domain.ListQuery) (pagination.Page[domain.Company], error) { r.query = query; r.listed = true; return pagination.Page[domain.Company]{}, nil }
func (*crmRepository) ListContacts(context.Context, domain.ListQuery) (pagination.Page[domain.Contact], error) { return pagination.Page[domain.Contact]{}, nil }
func (*crmRepository) ListPipelines(context.Context, domain.ListQuery) (pagination.Page[domain.Pipeline], error) { return pagination.Page[domain.Pipeline]{}, nil }
func (*crmRepository) ListStages(context.Context, domain.ListQuery) (pagination.Page[domain.Stage], error) { return pagination.Page[domain.Stage]{}, nil }
func (*crmRepository) ListDeals(context.Context, domain.ListQuery) (pagination.Page[domain.Deal], error) { return pagination.Page[domain.Deal]{}, nil }
func (*crmRepository) ListActivities(context.Context, domain.ListQuery) (pagination.Page[domain.Activity], error) { return pagination.Page[domain.Activity]{}, nil }

