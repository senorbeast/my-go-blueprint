func TestCreateStageAuthorizesTenantPipelineAndValidatesInput(t *testing.T) {
	ctx := context.Background()
	principal := auth.Principal{UserID: "owner", OrganizationID: "tenant-a"}
	pipelineID := domain.ID("00000000-0000-0000-0000-000000000051")
	repo := &crmRepository{pipeline: domain.Pipeline{ID: pipelineID, OrganizationID: "tenant-a"}}
	service := New(repo, organizationauthorization.New(&crmPermissions{permissions: []authorization.Permission{"platform.admin"}}), crmIDs{}, crmClock{})
	stage, err := service.CreateStage(ctx, principal, "tenant-a", CreateStage{PipelineID: string(pipelineID), Name: "  Qualified  ", Position: 1})
	if err != nil { t.Fatalf("create stage = %v", err) }
	if !repo.stageCreated || repo.stage != stage { t.Fatalf("created stage = %+v, stored = %+v", stage, repo.stage) }
	if stage.ID != "00000000-0000-0000-0000-000000000050" || stage.OrganizationID != "tenant-a" || stage.PipelineID != pipelineID || stage.Name != "Qualified" || stage.Position != 1 { t.Fatalf("stage = %+v", stage) }

	if _, err = service.CreateStage(ctx, principal, "tenant-b", CreateStage{PipelineID: string(pipelineID), Name: "Qualified", Position: 1}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("cross-tenant error = %v", err) }
	denied := New(&crmRepository{pipeline: repo.pipeline}, organizationauthorization.New(&crmPermissions{}), crmIDs{}, crmClock{})
	if _, err = denied.CreateStage(ctx, principal, "tenant-a", CreateStage{PipelineID: string(pipelineID), Name: "Qualified", Position: 1}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("unprivileged member error = %v", err) }
	if _, err = service.CreateStage(ctx, principal, "tenant-a", CreateStage{PipelineID: string(pipelineID), Name: " ", Position: 1}); err == nil { t.Fatal("blank stage name accepted") }
	if _, err = service.CreateStage(ctx, principal, "tenant-a", CreateStage{PipelineID: string(pipelineID), Name: "Qualified", Position: -1}); err == nil { t.Fatal("negative stage position accepted") }
	if _, err = service.CreateStage(ctx, principal, "tenant-a", CreateStage{PipelineID: "other-pipeline", Name: "Qualified", Position: 1}); err == nil { t.Fatal("unknown pipeline accepted") }
}

func TestCreateDealAuthorizesTenantReferencesAndValidatesInput(t *testing.T) {
	ctx := context.Background()
	principal := auth.Principal{UserID: "owner", OrganizationID: "tenant-a"}
	companyID := domain.ID("00000000-0000-0000-0000-000000000051")
	pipelineID := domain.ID("00000000-0000-0000-0000-000000000052")
	stageID := domain.ID("00000000-0000-0000-0000-000000000053")
	repo := &crmRepository{company: domain.Company{ID: companyID, OrganizationID: "tenant-a"}, pipeline: domain.Pipeline{ID: pipelineID, OrganizationID: "tenant-a"}, stage: domain.Stage{ID: stageID, OrganizationID: "tenant-a", PipelineID: pipelineID}}
	service := New(repo, organizationauthorization.New(&crmPermissions{permissions: []authorization.Permission{"platform.admin"}}), crmIDs{}, crmClock{})
	deal, err := service.CreateDeal(ctx, principal, "tenant-a", CreateDeal{CompanyID: string(companyID), PipelineID: string(pipelineID), StageID: string(stageID), Name: "  Enterprise  ", ValueCents: 9000})
	if err != nil { t.Fatalf("create deal = %v", err) }
	if !repo.dealCreated || repo.deal != deal { t.Fatalf("created deal = %+v, stored = %+v", deal, repo.deal) }
	if deal.OrganizationID != "tenant-a" || deal.CompanyID != companyID || deal.PipelineID != pipelineID || deal.StageID != stageID || deal.Name != "Enterprise" || deal.ValueCents != 9000 { t.Fatalf("deal = %+v", deal) }

	if _, err = service.CreateDeal(ctx, principal, "tenant-b", CreateDeal{CompanyID: string(companyID), PipelineID: string(pipelineID), StageID: string(stageID), Name: "Enterprise"}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("cross-tenant error = %v", err) }
	denied := New(repo, organizationauthorization.New(&crmPermissions{}), crmIDs{}, crmClock{})
	if _, err = denied.CreateDeal(ctx, principal, "tenant-a", CreateDeal{CompanyID: string(companyID), PipelineID: string(pipelineID), StageID: string(stageID), Name: "Enterprise"}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("unprivileged member error = %v", err) }
	if _, err = service.CreateDeal(ctx, principal, "tenant-a", CreateDeal{CompanyID: string(companyID), PipelineID: string(pipelineID), StageID: string(stageID), Name: " ", ValueCents: 1}); err == nil { t.Fatal("blank deal name accepted") }
	if _, err = service.CreateDeal(ctx, principal, "tenant-a", CreateDeal{CompanyID: string(companyID), PipelineID: string(pipelineID), StageID: string(stageID), Name: "Enterprise", ValueCents: -1}); err == nil { t.Fatal("negative deal value accepted") }
	if _, err = service.CreateDeal(ctx, principal, "tenant-a", CreateDeal{CompanyID: "other-company", PipelineID: string(pipelineID), StageID: string(stageID), Name: "Enterprise"}); err == nil { t.Fatal("unknown company accepted") }
	if _, err = service.CreateDeal(ctx, principal, "tenant-a", CreateDeal{CompanyID: string(companyID), PipelineID: string(pipelineID), StageID: "other-stage", Name: "Enterprise"}); err == nil { t.Fatal("unknown stage accepted") }
	wrongPipeline := *repo
	wrongPipeline.stage.PipelineID = "other-pipeline"
	wrongService := New(&wrongPipeline, organizationauthorization.New(&crmPermissions{permissions: []authorization.Permission{"platform.admin"}}), crmIDs{}, crmClock{})
	if _, err = wrongService.CreateDeal(ctx, principal, "tenant-a", CreateDeal{CompanyID: string(companyID), PipelineID: string(pipelineID), StageID: string(stageID), Name: "Enterprise"}); err == nil { t.Fatal("mismatched pipeline/stage accepted") }
}

func TestCreateActivityAuthorizesTenantDealAndValidatesInput(t *testing.T) {
	ctx := context.Background()
	principal := auth.Principal{UserID: "owner", OrganizationID: "tenant-a"}
	dealID := domain.ID("00000000-0000-0000-0000-000000000054")
	repo := &crmRepository{deal: domain.Deal{ID: dealID, OrganizationID: "tenant-a"}}
	service := New(repo, organizationauthorization.New(&crmPermissions{permissions: []authorization.Permission{"platform.admin"}}), crmIDs{}, crmClock{})
	occurredAt := time.Date(2026, time.July, 13, 12, 0, 0, 0, time.UTC)
	activity, err := service.CreateActivity(ctx, principal, "tenant-a", CreateActivity{DealID: string(dealID), Kind: "  call  ", Note: "  Follow up  ", OccurredAt: occurredAt})
	if err != nil { t.Fatalf("create activity = %v", err) }
	if !repo.activityCreated || repo.activity != activity { t.Fatalf("created activity = %+v, stored = %+v", activity, repo.activity) }
	if activity.OrganizationID != "tenant-a" || activity.DealID != dealID || activity.Kind != "call" || activity.Note != "Follow up" || !activity.OccurredAt.Equal(occurredAt) { t.Fatalf("activity = %+v", activity) }

	if _, err = service.CreateActivity(ctx, principal, "tenant-b", CreateActivity{DealID: string(dealID), Kind: "call", OccurredAt: occurredAt}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("cross-tenant error = %v", err) }
	denied := New(repo, organizationauthorization.New(&crmPermissions{}), crmIDs{}, crmClock{})
	if _, err = denied.CreateActivity(ctx, principal, "tenant-a", CreateActivity{DealID: string(dealID), Kind: "call", OccurredAt: occurredAt}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("unprivileged member error = %v", err) }
	if _, err = service.CreateActivity(ctx, principal, "tenant-a", CreateActivity{DealID: "foreign-deal", Kind: "call", OccurredAt: occurredAt}); err == nil { t.Fatal("foreign deal accepted") }
	if _, err = service.CreateActivity(ctx, principal, "tenant-a", CreateActivity{DealID: string(dealID), Kind: " ", OccurredAt: occurredAt}); err == nil { t.Fatal("blank activity kind accepted") }
	if _, err = service.CreateActivity(ctx, principal, "tenant-a", CreateActivity{DealID: string(dealID), Kind: "call"}); err == nil { t.Fatal("zero activity time accepted") }
}
