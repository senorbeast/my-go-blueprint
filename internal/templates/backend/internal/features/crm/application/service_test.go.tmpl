	if _, err = denied.CreateCompany(ctx, principal, "tenant-a", CreateCompany{Name: "Acme"}); !errors.As(err, new(*platformerrors.Error)) { t.Fatalf("unprivileged member error = %v", err) }
	if _, err = service.CreateCompany(ctx, principal, "tenant-a", CreateCompany{Name: " "}); err == nil { t.Fatal("blank company name accepted") }
}

