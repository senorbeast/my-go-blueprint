package http

import (
	"context"

	"github.com/danielgtaylor/huma/v2"
	"{{.Module}}/backend/internal/features/organizations/application"
	"{{.Module}}/backend/internal/features/organizations/domain"
	platformauth "{{.Module}}/backend/internal/platform/auth"
	"{{.Module}}/backend/internal/platform/authorization"
	httpplatform "{{.Module}}/backend/internal/platform/http"
)

type Routes struct{ service *application.Service }

func New(service *application.Service) Routes { return Routes{service: service} }
func (Routes) Descriptor() httpplatform.Descriptor {
	permission := authorization.Permission("organizations.roles.assign")
	return httpplatform.Descriptor{Prefix: "/api/v1/organizations", Tags: []string{"Organizations"}, Authentication: httpplatform.Required, Permission: &permission}
}
func (r Routes) Register(reg httpplatform.Registrar) error {
	httpplatform.Register(reg, huma.Operation{OperationID: "create-organization", Method: "POST", Path: "/api/v1/organizations", Tags: []string{"Organizations"}}, func(ctx context.Context, in *CreateOrganizationInput) (*CreateOrganizationOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx)
		organization, err := r.service.Create(ctx, principal, in.Body.Name)
		if err != nil {
			return nil, err
		}
		return &CreateOrganizationOutput{Body: OrganizationBody{ID: string(organization.ID), Name: organization.Name}}, nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "assign-organization-role", Method: "PUT", Path: "/api/v1/organizations/{organizationID}/members/{userID}/role", Tags: []string{"Organizations"}}, func(ctx context.Context, in *AssignRoleInput) (*AssignRoleOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx)
		principal.OrganizationID = platformauth.OrganizationID(in.OrganizationID)
		if err := r.service.AssignRole(ctx, principal, platformauth.UserID(in.UserID), domain.RoleID(in.Body.RoleID)); err != nil {
			return nil, err
		}
		return &AssignRoleOutput{}, nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "list-organization-members", Method: "GET", Path: "/api/v1/organizations/{organizationID}/members", Tags: []string{"Organizations"}}, func(ctx context.Context, in *ListMembersInput) (*ListMembersOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx); principal.OrganizationID = platformauth.OrganizationID(in.OrganizationID)
		members, err := r.service.ListMembers(ctx, principal); if err != nil { return nil, err }
		out := &ListMembersOutput{}; out.Body.Members = make([]MemberBody, 0, len(members))
		for _, member := range members { roles := make([]RoleBody, 0, len(member.Roles)); for _, role := range member.Roles { roles = append(roles, RoleBody{ID: string(role.ID), Name: role.Name}) }; out.Body.Members = append(out.Body.Members, MemberBody{UserID: string(member.UserID), Email: member.Email, DisplayName: member.DisplayName, Roles: roles}) }
		return out, nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "list-organization-roles", Method: "GET", Path: "/api/v1/organizations/{organizationID}/roles", Tags: []string{"Organizations"}}, func(ctx context.Context, in *ListRolesInput) (*ListRolesOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx); principal.OrganizationID = platformauth.OrganizationID(in.OrganizationID)
		roles, err := r.service.ListRoles(ctx, principal); if err != nil { return nil, err }
		out := &ListRolesOutput{}; out.Body.Roles = make([]RoleBody, 0, len(roles)); for _, role := range roles { out.Body.Roles = append(out.Body.Roles, RoleBody{ID: string(role.ID), Name: role.Name}) }; return out, nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "list-organization-permission-catalog", Method: "GET", Path: "/api/v1/organizations/{organizationID}/permissions", Tags: []string{"Organizations"}}, func(ctx context.Context, in *ListPermissionCatalogInput) (*ListPermissionCatalogOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx); principal.OrganizationID = platformauth.OrganizationID(in.OrganizationID); permissions, err := r.service.PermissionCatalog(ctx, principal); if err != nil { return nil, err }; out := &ListPermissionCatalogOutput{}; for _, permission := range permissions { out.Body.Permissions = append(out.Body.Permissions, PermissionBody{ID: string(permission.ID), Name: string(permission.Name), Description: permission.Description, Group: permission.Group}) }; return out, nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "create-organization-role", Method: "POST", Path: "/api/v1/organizations/{organizationID}/roles", Tags: []string{"Organizations"}}, func(ctx context.Context, in *CreateRoleInput) (*CreateRoleOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx); principal.OrganizationID = platformauth.OrganizationID(in.OrganizationID); permissions := make([]authorization.Permission, len(in.Body.Permissions)); for i := range in.Body.Permissions { permissions[i] = authorization.Permission(in.Body.Permissions[i]) }; role, err := r.service.CreateRole(ctx, principal, in.Body.Name, permissions); if err != nil { return nil, err }; return &CreateRoleOutput{Body: RoleBody{ID: string(role.ID), Name: role.Name}}, nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "get-organization-role-permissions", Method: "GET", Path: "/api/v1/organizations/{organizationID}/roles/{roleID}/permissions", Tags: []string{"Organizations"}}, func(ctx context.Context, in *RolePermissionsInput) (*RolePermissionsOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx); principal.OrganizationID = platformauth.OrganizationID(in.OrganizationID); permissions, err := r.service.RolePermissions(ctx, principal, domain.RoleID(in.RoleID)); if err != nil { return nil, err }; out := &RolePermissionsOutput{}; for _, permission := range permissions { out.Body.Permissions = append(out.Body.Permissions, string(permission)) }; return out, nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "replace-organization-role-permissions", Method: "PUT", Path: "/api/v1/organizations/{organizationID}/roles/{roleID}/permissions", Tags: []string{"Organizations"}}, func(ctx context.Context, in *UpdateRolePermissionsInput) (*UpdateRolePermissionsOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx); principal.OrganizationID = platformauth.OrganizationID(in.OrganizationID); permissions := make([]authorization.Permission, len(in.Body.Permissions)); for i := range in.Body.Permissions { permissions[i] = authorization.Permission(in.Body.Permissions[i]) }; if err := r.service.UpdateRolePermissions(ctx, principal, domain.RoleID(in.RoleID), permissions); err != nil { return nil, err }; return &UpdateRolePermissionsOutput{}, nil
	})
	httpplatform.Register(reg, huma.Operation{OperationID: "add-organization-member", Method: "POST", Path: "/api/v1/organizations/{organizationID}/members", Tags: []string{"Organizations"}}, func(ctx context.Context, in *AddMemberInput) (*AddMemberOutput, error) {
		principal, _ := platformauth.PrincipalFrom(ctx); principal.OrganizationID = platformauth.OrganizationID(in.OrganizationID)
		command := application.CreateMember{Email: in.Body.Email, DisplayName: in.Body.DisplayName, Password: in.Body.Password, RoleID: domain.RoleID(in.Body.RoleID)}
		if err := r.service.CreateMember(ctx, principal, command); err != nil { return nil, err }; return &AddMemberOutput{}, nil
	})
	return nil
}
