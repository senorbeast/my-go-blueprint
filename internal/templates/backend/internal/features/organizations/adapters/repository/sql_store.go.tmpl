// SQLStore owns transaction boundaries and translates domain values to the
// generated sqlc query contract. No handwritten statements live in this adapter.
type SQLStore struct{ db *sql.DB }

func NewSQLStore(db *sql.DB) *SQLStore { return &SQLStore{db: db} }

func (s *SQLStore) CreateOrganizationWithOwner(ctx context.Context, organization domain.Organization, owner domain.Membership, role domain.Role, permission domain.Permission) error {
	tx, err := s.db.BeginTx(ctx, nil)
	if err != nil { return fmt.Errorf("begin organization transaction: %w", err) }
	defer tx.Rollback() //nolint:errcheck
	q := dbgen.New(s.db).WithTx(tx)
	organizationID, err := idValue(organization.ID); if err != nil { return err }
	ownerOrganizationID, err := idValue(owner.OrganizationID); if err != nil { return err }
	ownerUserID, err := idValue(owner.UserID); if err != nil { return err }
	if err = q.CreateOrganization(ctx, dbgen.CreateOrganizationParams{ID: organizationID, Name: organization.Name, CreatedAt: organization.CreatedAt}); err != nil { return fmt.Errorf("insert organization: %w", err) }
	if err = q.CreateMembership(ctx, dbgen.CreateMembershipParams{OrganizationID: ownerOrganizationID, UserID: ownerUserID}); err != nil { return fmt.Errorf("insert organization owner membership: %w", err) }
	{{if .RBAC}}
	roleID, err := idValue(role.ID); if err != nil { return err }
	roleOrganizationID, err := idValue(role.OrganizationID); if err != nil { return err }
	permissionID, err := idValue(permission.ID); if err != nil { return err }
	if err = q.CreateRole(ctx, dbgen.CreateRoleParams{ID: roleID, OrganizationID: roleOrganizationID, Name: role.Name}); err != nil { return fmt.Errorf("insert owner role: %w", err) }
	if err = q.CreatePermissionIfAbsent(ctx, dbgen.CreatePermissionIfAbsentParams{ID: permissionID, Name: string(permission.Name)}); err != nil { return fmt.Errorf("insert owner permission: %w", err) }
	if err = q.GrantRolePermissionByName(ctx, dbgen.GrantRolePermissionByNameParams{RoleID: roleID, Name: string(permission.Name)}); err != nil { return fmt.Errorf("grant owner permission: %w", err) }
	{{if eq .Database "mysql"}}assigned, err := q.AssignMembershipRole(ctx, dbgen.AssignMembershipRoleParams{OrganizationID: ownerOrganizationID, UserID: ownerUserID, ID: roleID, OrganizationID_2: ownerOrganizationID}){{else}}assigned, err := q.AssignMembershipRole(ctx, dbgen.AssignMembershipRoleParams{OrganizationID: ownerOrganizationID, UserID: ownerUserID, ID: roleID}){{end}}
	if err != nil { return fmt.Errorf("assign owner role: %w", err) }
	if assigned == 0 { return sql.ErrNoRows }
	{{end}}
	if err = tx.Commit(); err != nil { return fmt.Errorf("commit organization transaction: %w", err) }
	return nil
}

func (s *SQLStore) FindMembership(ctx context.Context, organizationID domain.ID, userID platformauth.UserID) (domain.Membership, error) {
	organizationValue, err := idValue(organizationID); if err != nil { return domain.Membership{}, err }
	userValue, err := idValue(userID); if err != nil { return domain.Membership{}, err }
	if _, err = dbgen.New(s.db).FindMembership(ctx, dbgen.FindMembershipParams{OrganizationID: organizationValue, UserID: userValue}); err != nil { return domain.Membership{}, fmt.Errorf("find membership: %w", err) }
	return domain.Membership{OrganizationID: organizationID, UserID: userID, Active: true}, nil
}

func (s *SQLStore) DefaultOrganization(ctx context.Context, userID platformauth.UserID) (domain.Organization, error) {
	userValue, err := idValue(userID); if err != nil { return domain.Organization{}, err }
	row, err := dbgen.New(s.db).GetDefaultOrganizationForUser(ctx, userValue)
	if err != nil { return domain.Organization{}, fmt.Errorf("find default organization: %w", err) }
	id, err := stringID(row.ID); if err != nil { return domain.Organization{}, err }
	return domain.Organization{ID: domain.ID(id), Name: row.Name, CreatedAt: row.CreatedAt}, nil
}

func (s *SQLStore) ListOrganizationsForUser(ctx context.Context, userID platformauth.UserID) ([]domain.Organization, error) {
	userValue, err := idValue(userID); if err != nil { return nil, err }
	rows, err := dbgen.New(s.db).ListOrganizationsForUser(ctx, userValue)
	if err != nil { return nil, fmt.Errorf("list user organizations: %w", err) }
	organizations := make([]domain.Organization, 0, len(rows))
	for _, row := range rows {
		id, err := stringID(row.ID); if err != nil { return nil, err }
		organizations = append(organizations, domain.Organization{ID: domain.ID(id), Name: row.Name, CreatedAt: row.CreatedAt})
	}
	return organizations, nil
}

