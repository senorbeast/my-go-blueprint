	added, err := dbgen.New(s.db).AddMembershipByEmail(ctx, dbgen.AddMembershipByEmailParams{OrganizationID: organizationValue, Email: email}); if err != nil { return fmt.Errorf("add organization member: %w", err) }; if added == 0 { return sql.ErrNoRows }; return nil
}

func (s *SQLStore) CreateMember(ctx context.Context, organizationID domain.ID, member domain.MemberAccount, passwordHash string, roleID domain.RoleID) error {
	tx, err := s.db.BeginTx(ctx, nil); if err != nil { return fmt.Errorf("begin member transaction: %w", err) }; defer tx.Rollback() //nolint:errcheck
	q := dbgen.New(s.db).WithTx(tx)
	organizationValue, err := idValue(organizationID); if err != nil { return err }; userValue, err := idValue(member.UserID); if err != nil { return err }; roleValue, err := idValue(roleID); if err != nil { return err }
	if err = q.CreateUser(ctx, dbgen.CreateUserParams{ID: userValue, Email: member.Email, DisplayName: member.DisplayName, CreatedAt: member.CreatedAt}); err != nil { return fmt.Errorf("create member user: %w", err) }
	if err = q.CreateUserCredential(ctx, dbgen.CreateUserCredentialParams{UserID: userValue, PasswordHash: passwordHash, CreatedAt: member.CreatedAt, UpdatedAt: member.CreatedAt}); err != nil { return fmt.Errorf("create member credential: %w", err) }
	if err = q.CreateMembership(ctx, dbgen.CreateMembershipParams{OrganizationID: organizationValue, UserID: userValue}); err != nil { return fmt.Errorf("create member membership: %w", err) }
	{{if eq .Database "mysql"}}assigned, err := q.AssignMembershipRole(ctx, dbgen.AssignMembershipRoleParams{OrganizationID: organizationValue, UserID: userValue, ID: roleValue, OrganizationID_2: organizationValue}){{else}}assigned, err := q.AssignMembershipRole(ctx, dbgen.AssignMembershipRoleParams{OrganizationID: organizationValue, UserID: userValue, ID: roleValue}){{end}}
	if err != nil { return fmt.Errorf("assign member role: %w", err) }; if assigned == 0 { return sql.ErrNoRows }
	if err = tx.Commit(); err != nil { return fmt.Errorf("commit member transaction: %w", err) }; return nil
}

func (s *SQLStore) ListPermissions(ctx context.Context, organizationID domain.ID, userID platformauth.UserID) ([]authorization.Permission, error) {
	organizationValue, err := idValue(organizationID); if err != nil { return nil, err }
	userValue, err := idValue(userID); if err != nil { return nil, err }
	values, err := dbgen.New(s.db).ListMembershipPermissions(ctx, dbgen.ListMembershipPermissionsParams{OrganizationID: organizationValue, UserID: userValue})
	if err != nil { return nil, fmt.Errorf("list membership permissions: %w", err) }
	permissions := make([]authorization.Permission, len(values))
	for index, value := range values { permissions[index] = authorization.Permission(value) }
	return permissions, nil
}

