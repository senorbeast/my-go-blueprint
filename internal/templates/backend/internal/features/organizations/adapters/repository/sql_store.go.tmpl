func (s *SQLStore) ListPermissions(ctx context.Context, organizationID domain.ID, userID platformauth.UserID) ([]authorization.Permission, error) {
	organizationValue, err := idValue(organizationID); if err != nil { return nil, err }
	userValue, err := idValue(userID); if err != nil { return nil, err }
	values, err := dbgen.New(s.db).ListMembershipPermissions(ctx, dbgen.ListMembershipPermissionsParams{OrganizationID: organizationValue, UserID: userValue})
	if err != nil { return nil, fmt.Errorf("list membership permissions: %w", err) }
	permissions := make([]authorization.Permission, len(values))
	for index, value := range values { permissions[index] = authorization.Permission(value) }
	return permissions, nil
}

func (s *SQLStore) AssignRole(ctx context.Context, organizationID domain.ID, userID platformauth.UserID, roleID domain.RoleID) error {
	organizationValue, err := idValue(organizationID); if err != nil { return err }
	userValue, err := idValue(userID); if err != nil { return err }
	roleValue, err := idValue(roleID); if err != nil { return err }
	{{if eq .Database "mysql"}}assigned, err := dbgen.New(s.db).AssignMembershipRole(ctx, dbgen.AssignMembershipRoleParams{OrganizationID: organizationValue, UserID: userValue, ID: roleValue, OrganizationID_2: organizationValue}){{else}}assigned, err := dbgen.New(s.db).AssignMembershipRole(ctx, dbgen.AssignMembershipRoleParams{OrganizationID: organizationValue, UserID: userValue, ID: roleValue}){{end}}
	if err != nil { return fmt.Errorf("assign membership role: %w", err) }
	if assigned == 0 { return sql.ErrNoRows }
	return nil
}
