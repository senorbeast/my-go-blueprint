{{if eq .Database "mysql"}}
func idValue(value any) ([]byte, error) { return decodeID(fmt.Sprint(value)) }
func stringID(value []byte) (string, error) { if len(value) != 16 { return "", fmt.Errorf("unexpected UUID length %d", len(value)) }; encoded := hex.EncodeToString(value); return encoded[0:8]+"-"+encoded[8:12]+"-"+encoded[12:16]+"-"+encoded[16:20]+"-"+encoded[20:32], nil }
func decodeID(value string) ([]byte, error) { compact := strings.ReplaceAll(value, "-", ""); if len(compact) != 32 { return nil, fmt.Errorf("invalid UUID %q", value) }; id, err := hex.DecodeString(compact); if err != nil { return nil, fmt.Errorf("decode UUID: %w", err) }; return id, nil }
{{else}}
func idValue(value any) (uuid.UUID, error) { id, err := uuid.Parse(fmt.Sprint(value)); if err != nil { return uuid.UUID{}, fmt.Errorf("parse UUID %q: %w", value, err) }; return id, nil }
func stringID(value uuid.UUID) (string, error) { return value.String(), nil }
