func (s *SQLStore) ListPermissionCatalog(ctx context.Context) ([]domain.Permission, error) {
	rows, err := dbgen.New(s.db).ListPermissionCatalog(ctx); if err != nil { return nil, fmt.Errorf("list permission catalog: %w", err) }
	values := make([]domain.Permission, 0, len(rows)); for _, row := range rows { id, err := stringID(row.ID); if err != nil { return nil, err }; values = append(values, domain.Permission{ID: domain.PermissionID(id), Name: authorization.Permission(row.Name), Description: row.Description, Group: permissionGroup(row.Name)}) }; return values, nil
}
func (s *SQLStore) ListRolePermissions(ctx context.Context, organizationID domain.ID, roleID domain.RoleID) ([]authorization.Permission, error) {
	o, err := idValue(organizationID); if err != nil { return nil, err }; role, err := idValue(roleID); if err != nil { return nil, err }; rows, err := dbgen.New(s.db).ListRolePermissions(ctx, dbgen.ListRolePermissionsParams{OrganizationID: o, ID: role}); if err != nil { return nil, fmt.Errorf("list role permissions: %w", err) }; values := make([]authorization.Permission, len(rows)); for i := range rows { values[i] = authorization.Permission(rows[i]) }; return values, nil
}
func (s *SQLStore) CreateRoleWithPermissions(ctx context.Context, organizationID domain.ID, role domain.Role, permissions []authorization.Permission) error {
	tx, err := s.db.BeginTx(ctx, nil); if err != nil { return fmt.Errorf("begin role transaction: %w", err) }; defer tx.Rollback() //nolint:errcheck
	q := dbgen.New(s.db).WithTx(tx); o, err := idValue(organizationID); if err != nil { return err }; id, err := idValue(role.ID); if err != nil { return err }
	if err = q.CreateRole(ctx, dbgen.CreateRoleParams{ID: id, OrganizationID: o, Name: role.Name}); err != nil { return fmt.Errorf("create role: %w", err) }; for _, permission := range permissions { if err = q.GrantRolePermissionByName(ctx, dbgen.GrantRolePermissionByNameParams{RoleID: id, Name: string(permission)}); err != nil { return fmt.Errorf("grant role permission: %w", err) } }; return tx.Commit()
}
func (s *SQLStore) ReplaceRolePermissions(ctx context.Context, organizationID domain.ID, roleID domain.RoleID, permissions []authorization.Permission) error {
	tx, err := s.db.BeginTx(ctx, nil); if err != nil { return fmt.Errorf("begin role grants transaction: %w", err) }; defer tx.Rollback() //nolint:errcheck
	q := dbgen.New(s.db).WithTx(tx); o, err := idValue(organizationID); if err != nil { return err }; id, err := idValue(roleID); if err != nil { return err }; rolePermissions, err := q.ListRolePermissions(ctx, dbgen.ListRolePermissionsParams{OrganizationID: o, ID: id}); if err != nil { return fmt.Errorf("find role: %w", err) }; _ = rolePermissions
	if err = q.DeleteRolePermissions(ctx, id); err != nil { return fmt.Errorf("clear role permissions: %w", err) }; for _, permission := range permissions { if err = q.GrantRolePermissionByName(ctx, dbgen.GrantRolePermissionByNameParams{RoleID: id, Name: string(permission)}); err != nil { return fmt.Errorf("grant role permission: %w", err) } }; return tx.Commit()
}
func permissionGroup(name string) string { for i, c := range name { if c == '.' { return name[:i] } }; return "workspace" }

func (s *SQLStore) AddMembershipByEmail(ctx context.Context, organizationID domain.ID, email string) error {
