func (s *SQLStore) ListMembers(ctx context.Context, organizationID domain.ID) ([]domain.Member, error) {
	organizationValue, err := idValue(organizationID); if err != nil { return nil, err }
	rows, err := dbgen.New(s.db).ListOrganizationMembers(ctx, organizationValue)
	if err != nil { return nil, fmt.Errorf("list organization members: %w", err) }
	members := make([]domain.Member, 0, len(rows)); byUser := make(map[string]int, len(rows))
	for _, row := range rows {
		userID, err := stringID(row.UserID); if err != nil { return nil, err }
		index, exists := byUser[userID]
		if !exists { index = len(members); byUser[userID] = index; members = append(members, domain.Member{Membership: domain.Membership{OrganizationID: organizationID, UserID: platformauth.UserID(userID), Active: true}, Email: row.Email, DisplayName: row.DisplayName, Roles: []domain.Role{}}) }
		if row.RoleID.Valid { {{if eq .Database "mysql"}}roleID, err := stringID([]byte(row.RoleID.String)){{else}}roleID, err := stringID(row.RoleID.UUID){{end}}; if err != nil { return nil, err }; members[index].Roles = append(members[index].Roles, domain.Role{ID: domain.RoleID(roleID), OrganizationID: organizationID, Name: row.RoleName.String}) }
	}
