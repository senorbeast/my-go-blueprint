package domain

import (
	"context"
	"errors"
	"strings"
	"time"

	platformauth "{{.Module}}/backend/internal/platform/auth"
	"{{.Module}}/backend/internal/platform/authorization"
)

var ErrInvalidName = errors.New("organization name is required")
var ErrInvalidMember = errors.New("member email, display name, and password are required")
var ErrInvalidRole = errors.New("role name is required")
var ErrProtectedRole = errors.New("the owner role and platform.admin permission are reserved")
var ErrRoleNotFound = errors.New("organization role was not found")

type ID = platformauth.OrganizationID
type RoleID string
type PermissionID string

type Organization struct {
	ID        ID
	Name      string
	CreatedAt time.Time
}

func New(id ID, name string, createdAt time.Time) (Organization, error) {
	name = strings.TrimSpace(name)
	if name == "" {
		return Organization{}, ErrInvalidName
	}
	return Organization{ID: id, Name: name, CreatedAt: createdAt}, nil
}

type Membership struct {
	OrganizationID ID
	UserID         platformauth.UserID
	Active         bool
	CreatedAt      time.Time
}
// Member is the workspace-administration projection. It intentionally
// contains no credential material; it is safe to return from an HTTP list.
type Member struct {
	Membership
	Email       string
	DisplayName string
	Roles       []Role
}
type MemberAccount struct {
	UserID      platformauth.UserID
	Email       string
	DisplayName string
	CreatedAt   time.Time
}
type Role struct {
	ID             RoleID
	OrganizationID ID
	Name           string
}
type Permission struct {
	ID   PermissionID
	Name authorization.Permission
	Description string
	Group string
}

type Repository interface {
	Create(context.Context, Organization, Membership, Role, Permission) error
	FindMembership(context.Context, ID, platformauth.UserID) (Membership, error)
	DefaultOrganization(context.Context, platformauth.UserID) (Organization, error)
	Permissions(context.Context, ID, platformauth.UserID) ([]authorization.Permission, error)
	ListMembers(context.Context, ID) ([]Member, error)
	ListRoles(context.Context, ID) ([]Role, error)
	ListPermissionCatalog(context.Context, ID) ([]Permission, error)
	RolePermissions(context.Context, ID, RoleID) ([]authorization.Permission, error)
	CreateRole(context.Context, ID, Role, []authorization.Permission) error
	ReplaceRolePermissions(context.Context, ID, RoleID, []authorization.Permission) error
	AddMemberByEmail(context.Context, ID, string) error
	CreateMember(context.Context, ID, MemberAccount, string, RoleID) error
	AssignRole(context.Context, ID, platformauth.UserID, RoleID) error
}
