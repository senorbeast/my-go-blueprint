package domain

import (
	"errors"
	"net/mail"
	"strings"
)

var ErrInvalidMessage = errors.New("email message is invalid")

// Message is provider-neutral. Feature code submits this value without
// importing SMTP or a vendor SDK.
type Message struct {
	To      string
	Subject string
	Text    string
}

func NewMessage(to, subject, text string) (Message, error) {
	to, subject, text = strings.TrimSpace(to), strings.TrimSpace(subject), strings.TrimSpace(text)
	if _, err := mail.ParseAddress(to); err != nil || subject == "" || text == "" {
		return Message{}, ErrInvalidMessage
	}
	return Message{To: to, Subject: subject, Text: text}, nil
}
