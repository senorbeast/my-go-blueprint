services:
  db:
    image: mysql:8.4
    environment: {MYSQL_USER: app, MYSQL_PASSWORD: app, MYSQL_DATABASE: app, MYSQL_ROOT_PASSWORD: root}
    ports: ["3306:3306"]
    healthcheck: {test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-uapp", "-papp"], interval: 2s, timeout: 2s, retries: 30}
    volumes: ["db-data:/var/lib/mysql"]
volumes: {db-data: {}}

