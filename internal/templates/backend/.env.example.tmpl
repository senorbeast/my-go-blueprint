APP_ENV=development
HTTP_ADDRESS=:8080
DATABASE_URL={{if eq .Database "postgres"}}postgres://app:app@localhost:5432/app?sslmode=disable{{else}}app:app@tcp(localhost:3306)/app?parseTime=true{{end}}
QUEUE_DRIVER=sql
RABBITMQ_URL=amqp://app:app@localhost:5672/
{{if .Email}}# The development worker currently uses the safe log mail adapter. Mailpit
# listens on localhost:1025 when started and is ready for an SMTP adapter.
MAILPIT_SMTP_ADDRESS=localhost:1025
MAILPIT_UI_URL=http://localhost:8025
{{end}}
{{if .Cache}}CACHE_DRIVER=redis
CACHE_URL=redis://localhost:6379/0
CACHE_PREFIX=app
{{end}}
LOG_LEVEL=debug
CURSOR_SECRET=replace-with-at-least-32-random-bytes
JWT_SECRET=replace-with-at-least-32-random-bytes
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173
