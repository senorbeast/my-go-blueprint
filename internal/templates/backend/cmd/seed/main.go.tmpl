package main

import (
	"context"
	"database/sql"
	"flag"
	"fmt"
	"os"
{{if .Auth}}	"golang.org/x/crypto/bcrypt"
{{end}}
{{if eq .Database "postgres"}}	_ "github.com/jackc/pgx/v5/stdlib"
{{else}}	_ "github.com/go-sql-driver/mysql"
{{end}})

func main() {
	profile := flag.String("profile", "{{.Seed}}", "none, minimal, or demo")
	flag.Parse()
	if *profile == "none" { fmt.Println("seed profile none selected"); return }
	if *profile != "minimal" && *profile != "demo" { panic("unsupported seed profile: " + *profile) }
	dsn := os.Getenv("DATABASE_URL")
	if dsn == "" { panic("DATABASE_URL is required") }
	const driver = "{{if eq .Database "postgres"}}pgx{{else}}mysql{{end}}"
	db, err := sql.Open(driver, dsn)
	if err != nil { panic(err) }
	defer db.Close()
	ctx := context.Background()
	tx, err := db.BeginTx(ctx, nil)
	if err != nil { panic(err) }
	defer tx.Rollback()
	statements := minimalStatements()
	if *profile == "demo" { statements = append(statements, demoStatements()...) }
	for _, statement := range statements {
		if _, err := tx.ExecContext(ctx, statement); err != nil { panic(fmt.Errorf("seed statement: %w", err)) }
	}
{{if .Auth}}	passwordHash, err := bcrypt.GenerateFromPassword([]byte(demoPassword), bcrypt.DefaultCost)
	if err != nil { panic(fmt.Errorf("hash demo credential: %w", err)) }
	if _, err := tx.ExecContext(ctx, demoCredentialStatement, passwordHash); err != nil { panic(fmt.Errorf("seed demo credential: %w", err)) }
{{end}}
	if err := tx.Commit(); err != nil { panic(err) }
	fmt.Printf("seed profile %s applied idempotently\n", *profile)
}

{{if .Auth}}const demoPassword = "DemoPass123!"

