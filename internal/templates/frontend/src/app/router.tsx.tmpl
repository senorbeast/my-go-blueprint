import { createRootRoute, createRoute, createRouter, Link, Outlet } from "@tanstack/react-router";
{{if .Auth}}
import { AuthShell } from "@/features/auth/auth-shell";
{{end}}{{if or .CMS .CRM}}import { useAuthUI } from "@/features/auth/auth-store";
{{end}}{{if .CMS}}
import { CMSAdmin } from "@/features/cms/cms-admin";
{{end}}{{if .CRM}}
import { CRMAdmin } from "@/features/crm/crm-admin";
{{end}}

{{if .CMS}}function CMSPage() {
  const organizationId = useAuthUI((state) => state.activeOrganizationId);
  const permissions = useAuthUI((state) => state.permissions);
  if (!organizationId) return <main className="p-8">Select an organization to manage content.</main>;
  return <CMSAdmin organizationId={organizationId} canCreate={permissions.includes("cms.posts.create")} />;
}
{{end}}{{if .CRM}}function CRMPage() {
  const organizationID = useAuthUI((state) => state.activeOrganizationId);
  const permissions = useAuthUI((state) => state.permissions);
  if (!organizationID) return <main className="p-8">Select an organization to open CRM.</main>;
  return <CRMAdmin organizationID={organizationID} permissions={permissions} />;
}
{{end}}

const rootRoute = createRootRoute({ component: () => <><header className="flex gap-4 border-b bg-white px-6 py-4"><Link to="/" className="font-semibold">{{ .Name }}</Link>{{if .CMS}}<Link to="/cms">CMS</Link>{{end}}{{if .CRM}}<Link to="/crm">CRM</Link>{{end}}</header><Outlet /></> });
{{if .Auth}}
const indexRoute = createRoute({ getParentRoute: () => rootRoute, path: "/", component: AuthShell });
{{else}}
const indexRoute = createRoute({ getParentRoute: () => rootRoute, path: "/", component: () => <main className="p-8"><h1 className="text-2xl font-semibold">{{.Name}}</h1><p className="mt-2 text-slate-600">Backend is ready. Add a feature to begin.</p></main> });
{{end}}{{if .CMS}}
const cmsRoute = createRoute({ getParentRoute: () => rootRoute, path: "/cms", component: CMSPage });
{{end}}{{if .CRM}}
const crmRoute = createRoute({ getParentRoute: () => rootRoute, path: "/crm", component: CRMPage });
{{end}}
const routeTree = rootRoute.addChildren([indexRoute{{if .CMS}}, cmsRoute{{end}}{{if .CRM}}, crmRoute{{end}}]);
export const router = createRouter({ routeTree, defaultPreload: "intent" });
declare module "@tanstack/react-router" { interface Register { router: typeof router } }
