import { type FormEvent, useState } from "react";
import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
import { createCMSPost, listCMSPosts, publishCMSPost } from "./api";

export interface CMSAdminProps { organizationId: string; canCreate?: boolean; canPublish?: boolean }
const emptyDraft = { slug: "", title: "", body: "" };

export function CMSAdmin({ organizationId, canCreate = false, canPublish = canCreate }: CMSAdminProps) {
  const [draft, setDraft] = useState(emptyDraft);
  const [isCreating, setIsCreating] = useState(false);
  const queryClient = useQueryClient();
  const posts = useQuery({ queryKey: ["cms", organizationId, "posts"], queryFn: () => listCMSPosts({ organizationId }) });
  const invalidatePosts = () => queryClient.invalidateQueries({ queryKey: ["cms", organizationId, "posts"] });
  const createPost = useMutation({ mutationFn: createCMSPost, onSuccess: () => { setDraft(emptyDraft); setIsCreating(false); return invalidatePosts(); } });
  const publishPost = useMutation({ mutationFn: (postId: string) => publishCMSPost(organizationId, postId), onSuccess: invalidatePosts });
  const submitDraft = (event: FormEvent<HTMLFormElement>) => { event.preventDefault(); createPost.mutate({ organizationId, ...draft }); };

  if (posts.isPending) return <main className="p-8">Loading content...</main>;
  if (posts.isError) return <main role="alert" className="p-8 text-red-700">Unable to load content.</main>;
  return <main className="mx-auto max-w-6xl p-8">
    <header className="flex items-center justify-between"><div><h1 className="text-2xl font-semibold">Content</h1><p className="text-slate-600">Create drafts, then publish when they are ready.</p></div>{canCreate && <button type="button" onClick={() => setIsCreating((value) => !value)} className="rounded bg-slate-900 px-4 py-2 text-white">{isCreating ? "Close editor" : "New post"}</button>}</header>
    {isCreating && <form onSubmit={submitDraft} className="mt-6 grid gap-3 rounded border p-4" aria-label="New post form"><label>Title<input required value={draft.title} onChange={(event) => setDraft({ ...draft, title: event.target.value })} className="ml-2 rounded border px-2 py-1" /></label><label>Slug<input required value={draft.slug} onChange={(event) => setDraft({ ...draft, slug: event.target.value })} className="ml-2 rounded border px-2 py-1" /></label><label>Body<textarea required value={draft.body} onChange={(event) => setDraft({ ...draft, body: event.target.value })} className="mt-1 block w-full rounded border p-2" /></label>{createPost.isError && <p role="alert" className="text-red-700">Unable to create this draft. Check the details and try again.</p>}<button disabled={createPost.isPending} className="w-fit rounded bg-slate-900 px-4 py-2 text-white">{createPost.isPending ? "Creating..." : "Create draft"}</button></form>}
    {posts.data.items.length === 0 ? <p className="mt-8 text-slate-600">No posts yet. Create a draft to start your editorial workflow.</p> : <ul className="mt-8 divide-y rounded border">{posts.data.items.map((post) => <li key={post.id} className="flex items-center justify-between gap-4 p-4"><div><h2 className="font-medium">{post.title}</h2><p className="text-sm text-slate-500">/{post.slug}</p></div><div className="flex items-center gap-3"><span className="rounded bg-slate-100 px-2 py-1 text-xs uppercase">{post.status}</span>{canPublish && post.status === "draft" && <button type="button" onClick={() => publishPost.mutate(post.id)} disabled={publishPost.isPending} className="rounded border px-3 py-1">Publish</button>}</div></li>)}</ul>}
    {publishPost.isError && <p role="alert" className="mt-4 text-red-700">Unable to publish this post. Ensure it has a title and body, then try again.</p>}
  </main>;
}
