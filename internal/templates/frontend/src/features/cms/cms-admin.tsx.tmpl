import { type FormEvent, useMemo, useState } from "react";
import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
import { FilePenLine, Plus, Search } from "lucide-react";
import { createCMSPost, listCMSPosts, publishCMSPost } from "./api";
import type { PostStatus } from "./contracts";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from "@/components/ui/card";

export interface CMSAdminProps { organizationId: string; canCreate?: boolean; canPublish?: boolean }
const emptyDraft = { slug: "", title: "", body: "" };
type ContentFilter = "all" | PostStatus;
const filterOptions: Array<{ label: string; value: ContentFilter }> = [{ label: "All content", value: "all" }, { label: "Drafts", value: "draft" }, { label: "Published", value: "published" }, { label: "Archived", value: "archived" }];

function statusLabel(status: PostStatus) { return status === "draft" ? "Draft" : status === "published" ? "Published" : "Archived"; }

export function CMSAdmin({ organizationId, canCreate = false, canPublish = canCreate }: CMSAdminProps) {
  const [draft, setDraft] = useState(emptyDraft);
  const [isCreating, setIsCreating] = useState(false);
  const [filter, setFilter] = useState<ContentFilter>("all");
  const [search, setSearch] = useState("");
  const queryClient = useQueryClient();
  const posts = useQuery({ queryKey: ["cms", organizationId, "posts", filter, search], queryFn: () => listCMSPosts({ organizationId, status: filter === "all" ? undefined : filter, search }) });
  const invalidatePosts = () => queryClient.invalidateQueries({ queryKey: ["cms", organizationId, "posts"] });
  const createPost = useMutation({ mutationFn: createCMSPost, onSuccess: () => { setDraft(emptyDraft); setIsCreating(false); return invalidatePosts(); } });
  const publishPost = useMutation({ mutationFn: (postId: string) => publishCMSPost(organizationId, postId), onSuccess: invalidatePosts });
  const submitDraft = (event: FormEvent<HTMLFormElement>) => { event.preventDefault(); createPost.mutate({ organizationId, ...draft }); };
  const totals = useMemo(() => ({ draft: posts.data?.items.filter((post) => post.status === "draft").length ?? 0, published: posts.data?.items.filter((post) => post.status === "published").length ?? 0 }), [posts.data]);

  if (posts.isPending) return <main className="mx-auto max-w-7xl p-8 text-muted-foreground">Loading editorial workspace...</main>;
  if (posts.isError) return <main role="alert" className="mx-auto max-w-7xl p-8 text-destructive">Unable to load content. Refresh the page and try again.</main>;
  const emptyLabel = filter === "all" ? "No posts yet." : `No ${filter} posts yet.`;
  return <main className="mx-auto flex max-w-7xl flex-col gap-6 px-4 py-8 sm:px-6">
    <header className="flex flex-wrap items-start justify-between gap-4"><div className="space-y-2"><Badge className="w-fit">Editorial workspace</Badge><h1 className="text-3xl font-bold tracking-tight">Content</h1><p className="max-w-2xl text-muted-foreground">Review the publishing queue, turn ideas into drafts, and publish finished work with confidence.</p></div>{canCreate && <Button type="button" onClick={() => setIsCreating((value) => !value)}><Plus data-icon="inline-start" />{isCreating ? "Close editor" : "New post"}</Button>}</header>
    <section aria-label="Content overview" className="grid gap-4 sm:grid-cols-3"><Card><CardHeader className="pb-2"><CardDescription>Visible in this view</CardDescription><CardTitle className="text-2xl">{posts.data.items.length} posts</CardTitle></CardHeader></Card><Card><CardHeader className="pb-2"><CardDescription>Waiting for review</CardDescription><CardTitle className="text-2xl">{totals.draft} drafts</CardTitle></CardHeader></Card><Card><CardHeader className="pb-2"><CardDescription>Live content</CardDescription><CardTitle className="text-2xl">{totals.published} published</CardTitle></CardHeader></Card></section>
    <Card><CardContent className="flex flex-col gap-4 p-4 sm:flex-row sm:items-center sm:justify-between"><div className="flex flex-wrap gap-2" role="group" aria-label="Content status"><>{filterOptions.map((option) => <Button key={option.value} type="button" size="sm" variant={filter === option.value ? "secondary" : "ghost"} onClick={() => setFilter(option.value)}>{option.label}</Button>)}</></div><label className="relative block sm:w-72"><span className="sr-only">Search content</span><Search className="pointer-events-none absolute left-3 top-2.5 h-4 w-4 text-muted-foreground" /><input value={search} onChange={(event) => setSearch(event.target.value)} placeholder="Search title or body" className="h-9 w-full rounded-md border bg-background pl-9 pr-3 text-sm outline-none focus-visible:ring-2 focus-visible:ring-ring" /></label></CardContent></Card>
    {isCreating && <Card><CardHeader><CardTitle>New draft</CardTitle><CardDescription>Start with the essentials. This post stays private until you publish it.</CardDescription></CardHeader><CardContent><form onSubmit={submitDraft} className="grid gap-4" aria-label="New post form"><label className="grid gap-2 text-sm font-medium">Title<input required value={draft.title} onChange={(event) => setDraft({ ...draft, title: event.target.value })} className="h-10 rounded-md border bg-background px-3" /></label><label className="grid gap-2 text-sm font-medium">Slug<input required value={draft.slug} onChange={(event) => setDraft({ ...draft, slug: event.target.value })} className="h-10 rounded-md border bg-background px-3" /></label><label className="grid gap-2 text-sm font-medium">Body<textarea required value={draft.body} onChange={(event) => setDraft({ ...draft, body: event.target.value })} className="min-h-32 rounded-md border bg-background p-3" /></label>{createPost.isError && <p role="alert" className="text-sm text-destructive">Unable to create this draft. Check the details and try again.</p>}<div><Button disabled={createPost.isPending}>{createPost.isPending ? "Creating..." : "Create draft"}</Button></div></form></CardContent></Card>}
    {posts.data.items.length === 0 ? <Card><CardContent className="flex flex-col items-center gap-3 py-14 text-center"><FilePenLine className="h-8 w-8 text-muted-foreground" /><CardTitle>{emptyLabel}</CardTitle><CardDescription>{canCreate ? "Create a draft to start your editorial workflow." : "Ask a workspace editor for permission to create content."}</CardDescription></CardContent></Card> : <section aria-label="Posts" className="grid gap-4 lg:grid-cols-2">{posts.data.items.map((post) => <Card key={post.id}><CardHeader><div className="flex items-start justify-between gap-3"><div className="space-y-1"><CardTitle>{post.title}</CardTitle><CardDescription>/{post.slug}</CardDescription></div><Badge className={post.status === "published" ? "bg-emerald-700 text-white" : "bg-muted text-muted-foreground"}>{statusLabel(post.status)}</Badge></div></CardHeader><CardContent><p className="line-clamp-3 text-sm text-muted-foreground">{post.body}</p></CardContent><CardFooter className="flex items-center justify-between gap-3"><span className="text-xs text-muted-foreground">Updated {new Date(post.updatedAt).toLocaleDateString()}</span>{canPublish && post.status === "draft" && <Button type="button" size="sm" variant="outline" onClick={() => publishPost.mutate(post.id)} disabled={publishPost.isPending}>{publishPost.isPending ? "Publishing..." : "Publish"}</Button>}</CardFooter></Card>)}</section>}
    {publishPost.isError && <p role="alert" className="text-sm text-destructive">Unable to publish this post. Ensure it has a title and body, then try again.</p>}
  </main>;
}
