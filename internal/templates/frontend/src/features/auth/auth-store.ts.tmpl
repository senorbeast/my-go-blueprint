import { create } from "zustand";

export function hasPermission(permissions: readonly string[], required: string): boolean {
  return permissions.includes("platform.admin") || permissions.includes(required);
}

type AuthUIState = {
  activeOrganizationId?: string;
  permissions: readonly string[];
  setActiveOrganization: (id?: string) => void;
  setPermissions: (permissions: readonly string[]) => void;
  clearSession: () => void;
};
export const useAuthUI = create<AuthUIState>((set) => ({
  activeOrganizationId: undefined,
  permissions: [],
  setActiveOrganization: (activeOrganizationId) => set({ activeOrganizationId }),
  setPermissions: (permissions) => set({ permissions }),
  clearSession: () => set({ activeOrganizationId: undefined, permissions: [] }),
}));
