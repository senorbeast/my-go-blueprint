import { QueryClient, QueryClientProvider } from "@tanstack/react-query";
import { cleanup, fireEvent, render, screen } from "@testing-library/react";
import { afterEach, expect, test, vi } from "vitest";
import { AuthShell, SessionHydrator } from "./auth-shell";
import { useAuthUI } from "./auth-store";
afterEach(() => { cleanup(); vi.restoreAllMocks(); });
function renderAuth() { return render(<QueryClientProvider client={new QueryClient({ defaultOptions: { queries: { retry: false } } })}><AuthShell /></QueryClientProvider>); }
function ActiveOrganizationProbe() { const organizationId = useAuthUI((state) => state.activeOrganizationId); return <output>{organizationId ?? "no organization"}</output>; }
test("hydrates the active organization for a feature route after a page load", async () => { vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(JSON.stringify({ id: "user-1", email: "owner@example.test", organizationId: "org-1", permissions: ["platform.admin"] }), { status: 200 })); render(<QueryClientProvider client={new QueryClient({ defaultOptions: { queries: { retry: false } } })}><SessionHydrator /><ActiveOrganizationProbe /></QueryClientProvider>); expect(await screen.findByText("org-1")).toBeInTheDocument(); });
test("shows a usable sign-in form when the current-session endpoint is unavailable", async () => { vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(null, { status: 404 })); renderAuth(); expect(await screen.findByRole("heading", { name: "Welcome back" })).toBeInTheDocument(); expect(screen.getByRole("button", { name: "Sign in" })).toBeInTheDocument(); });
test("opens every selected demo workspace for a platform administrator", async () => { document.cookie = "csrf_token=csrf-test"; const fetch = vi.spyOn(globalThis, "fetch").mockResolvedValueOnce(new Response(null, { status: 404 })).mockResolvedValueOnce(new Response(JSON.stringify({}), { status: 200 })).mockResolvedValueOnce(new Response(JSON.stringify({ id: "user-1", email: "owner@example.test", displayName: "Demo Owner", organizationId: "org-1", permissions: ["platform.admin"] }), { status: 200 })); renderAuth(); await screen.findByRole("heading", { name: "Welcome back" }); fireEvent.change(screen.getByLabelText("Email address"), { target: { value: "owner@example.test" } }); fireEvent.change(screen.getByLabelText("Password"), { target: { value: "secret-pass" } }); fireEvent.click(screen.getByRole("button", { name: "Sign in" })); expect(await screen.findByRole("heading", { name: "Welcome, Demo Owner." })).toBeInTheDocument(); expect(fetch).toHaveBeenNthCalledWith(2, "/api/v1/auth/login", expect.objectContaining({ headers: expect.objectContaining({ "X-CSRF-Token": "csrf-test" }) })); {{if .Content}}expect(screen.getByRole("link", { name: "Open content" })).toBeInTheDocument();{{end}}{{if .Customers}}expect(screen.getByRole("link", { name: "Open customers" })).toBeInTheDocument();{{end}} });
