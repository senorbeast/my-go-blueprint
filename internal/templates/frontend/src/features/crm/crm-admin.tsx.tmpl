import { useEffect, useState } from "react";
import type { FormEvent } from "react";
import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
import type { CRMEntity, CRMRecord, CursorPage } from "./contracts";
import { hasPermission } from "@/features/auth/auth-store";

const sections: CRMEntity[] = ["companies", "contacts", "pipelines", "stages", "deals", "activities"];
const entityLabels: Record<CRMEntity, string> = { companies: "Companies", contacts: "Contacts", pipelines: "Pipelines", stages: "Stages", deals: "Deals", activities: "Activities" };
function csrfHeader(): Record<string, string> { const token = document.cookie.split("; ").find((entry) => entry.startsWith("csrf_token="))?.slice("csrf_token=".length); return token ? { "X-CSRF-Token": decodeURIComponent(token) } : {}; }
async function requestCRM<T>(path: string, init?: RequestInit): Promise<T> { const response = await fetch(path, { credentials: "include", ...init, headers: { "Content-Type": "application/json", ...csrfHeader(), ...init?.headers } }); if (!response.ok) throw new Error("The CRM request could not be completed."); return response.json() as Promise<T>; }
async function listCRM(organizationID: string, entity: CRMEntity): Promise<CursorPage<CRMRecord>> { return requestCRM<CursorPage<CRMRecord>>(`/api/v1/organizations/${organizationID}/crm/${entity}`); }
async function createCompany(organizationID: string, name: string): Promise<CRMRecord> { return requestCRM<CRMRecord>(`/api/v1/organizations/${organizationID}/crm/companies`, { method: "POST", body: JSON.stringify({ name }) }); }
async function updateCompany(organizationID: string, companyID: string, name: string): Promise<CRMRecord> { return requestCRM<CRMRecord>(`/api/v1/organizations/${organizationID}/crm/companies/${companyID}`, { method: "PATCH", body: JSON.stringify({ name }) }); }
async function createContact(organizationID: string, name: string, email: string): Promise<CRMRecord> { return requestCRM<CRMRecord>(`/api/v1/organizations/${organizationID}/crm/contacts`, { method: "POST", body: JSON.stringify({ name, email }) }); }
async function createPipeline(organizationID: string, name: string): Promise<CRMRecord> { return requestCRM<CRMRecord>(`/api/v1/organizations/${organizationID}/crm/pipelines`, { method: "POST", body: JSON.stringify({ name }) }); }
function CompaniesWorkspace({ organizationID, permissions }: { organizationID: string; permissions: readonly string[] }) {
  const client = useQueryClient(); const canCreate = hasPermission(permissions, "crm.companies.create"); const canUpdate = hasPermission(permissions, "crm.companies.update"); const [name, setName] = useState(""); const [editing, setEditing] = useState<CRMRecord | null>(null);
  const query = useQuery({ queryKey: ["crm", organizationID, "companies"], queryFn: () => listCRM(organizationID, "companies") });
  const create = useMutation({ mutationFn: () => createCompany(organizationID, name.trim()), onSuccess: (company) => { client.setQueryData<CursorPage<CRMRecord>>(["crm", organizationID, "companies"], (page) => page ? { ...page, items: [company, ...page.items] } : { items: [company], hasMore: false }); setName(""); } });
  const update = useMutation({ mutationFn: () => updateCompany(organizationID, editing!.id, name.trim()), onSuccess: (company) => { client.setQueryData<CursorPage<CRMRecord>>(["crm", organizationID, "companies"], (page) => page ? { ...page, items: page.items.map((item) => item.id === company.id ? company : item) } : page); setEditing(null); setName(""); } });
  const submit = (event: FormEvent) => { event.preventDefault(); if (!name.trim()) return; if (editing) update.mutate(); else create.mutate(); };
  if (query.isPending) return <p>Loading companies...</p>; if (query.isError) return <p role="alert">Unable to load companies.</p>;
  return <section aria-labelledby="companies-heading" className="space-y-5"><div><h2 id="companies-heading" className="text-xl font-semibold">Companies</h2><p className="text-sm text-slate-600">Track the accounts your team sells to and serves.</p></div>{canCreate || (editing && canUpdate) ? <form onSubmit={submit} className="flex max-w-xl gap-2"><label className="sr-only" htmlFor="company-name">Company name</label><input id="company-name" aria-label="Company name" className="min-w-0 flex-1 rounded border px-3 py-2" value={name} onChange={(event) => setName(event.target.value)} placeholder="e.g. Acme Inc." maxLength={200} /><button className="rounded bg-slate-900 px-4 py-2 text-white disabled:opacity-50" disabled={!name.trim() || create.isPending || update.isPending}>{editing ? "Save company" : "Add company"}</button>{editing && <button type="button" className="rounded border px-4 py-2" onClick={() => { setEditing(null); setName(""); }}>Cancel</button>}</form> : null}{create.isError || update.isError ? <p role="alert" className="text-red-700">The company could not be saved. Please try again.</p> : null}{query.data.items.length === 0 ? <p className="rounded border border-dashed p-6 text-slate-600">No companies yet.</p> : <ul className="divide-y rounded border">{query.data.items.map((company) => <li key={company.id} className="flex items-center justify-between gap-4 p-4"><div><h3 className="font-medium">{company.name ?? company.id}</h3><p className="text-sm text-slate-500">Added {new Date(company.createdAt).toLocaleDateString()}</p></div>{canUpdate ? <button className="rounded border px-3 py-1 text-sm" onClick={() => { setEditing(company); setName(company.name ?? ""); }}>Rename</button> : null}</li>)}</ul>}</section>;
}
function ContactsWorkspace({ organizationID, permissions }: { organizationID: string; permissions: readonly string[] }) {
  const client = useQueryClient();
  const canCreate = hasPermission(permissions, "crm.contacts.create");
  const [name, setName] = useState("");
  const [email, setEmail] = useState("");
  const query = useQuery({ queryKey: ["crm", organizationID, "contacts"], queryFn: () => listCRM(organizationID, "contacts") });
  const create = useMutation({
    mutationFn: () => createContact(organizationID, name.trim(), email.trim()),
    onSuccess: (contact) => {
      client.setQueryData<CursorPage<CRMRecord>>(["crm", organizationID, "contacts"], (page) => page ? { ...page, items: [contact, ...page.items] } : { items: [contact], hasMore: false });
      setName("");
      setEmail("");
    },
  });
  const submit = (event: FormEvent) => { event.preventDefault(); if (name.trim()) create.mutate(); };
  if (query.isPending) return <p>Loading contacts...</p>;
  if (query.isError) return <p role="alert">Unable to load contacts.</p>;
  return <section aria-labelledby="contacts-heading" className="space-y-5"><div><h2 id="contacts-heading" className="text-xl font-semibold">Contacts</h2><p className="text-sm text-slate-600">Keep the people you work with alongside their preferred email address.</p></div>{canCreate ? <form onSubmit={submit} className="grid max-w-xl gap-2 sm:grid-cols-2"><label className="sr-only" htmlFor="contact-name">Contact name</label><input id="contact-name" aria-label="Contact name" className="min-w-0 rounded border px-3 py-2" value={name} onChange={(event) => setName(event.target.value)} placeholder="e.g. Ada Lovelace" maxLength={200} required /><label className="sr-only" htmlFor="contact-email">Contact email</label><input id="contact-email" aria-label="Contact email" className="min-w-0 rounded border px-3 py-2" value={email} onChange={(event) => setEmail(event.target.value)} placeholder="ada@example.com (optional)" type="email" maxLength={320} /><button className="w-fit rounded bg-slate-900 px-4 py-2 text-white disabled:opacity-50 sm:col-span-2" disabled={!name.trim() || create.isPending}>Add contact</button></form> : null}{create.isError ? <p role="alert" className="text-red-700">The contact could not be saved. Please try again.</p> : null}{query.data.items.length === 0 ? <p className="rounded border border-dashed p-6 text-slate-600">No contacts yet.</p> : <ul className="divide-y rounded border">{query.data.items.map((contact) => <li key={contact.id} className="p-4"><h3 className="font-medium">{contact.name ?? contact.id}</h3>{contact.email ? <p className="text-sm text-slate-500">{contact.email}</p> : null}</li>)}</ul>}</section>;
}
function PipelinesWorkspace({ organizationID, permissions }: { organizationID: string; permissions: readonly string[] }) {
  const client = useQueryClient();
  const canCreate = hasPermission(permissions, "crm.pipelines.create");
  const [name, setName] = useState("");
  const query = useQuery({ queryKey: ["crm", organizationID, "pipelines"], queryFn: () => listCRM(organizationID, "pipelines") });
  const create = useMutation({
    mutationFn: () => createPipeline(organizationID, name.trim()),
    onSuccess: (pipeline) => {
      client.setQueryData<CursorPage<CRMRecord>>(["crm", organizationID, "pipelines"], (page) => page ? { ...page, items: [pipeline, ...page.items] } : { items: [pipeline], hasMore: false });
      setName("");
    },
  });
  const submit = (event: FormEvent) => { event.preventDefault(); if (name.trim()) create.mutate(); };
  if (query.isPending) return <p>Loading pipelines...</p>;
  if (query.isError) return <p role="alert">Unable to load pipelines.</p>;
  return <section aria-labelledby="pipelines-heading" className="space-y-5"><div><h2 id="pipelines-heading" className="text-xl font-semibold">Pipelines</h2><p className="text-sm text-slate-600">Organize the stages your sales team uses to move deals forward.</p></div>{canCreate ? <form onSubmit={submit} className="flex max-w-xl gap-2"><label className="sr-only" htmlFor="pipeline-name">Pipeline name</label><input id="pipeline-name" aria-label="Pipeline name" className="min-w-0 flex-1 rounded border px-3 py-2" value={name} onChange={(event) => setName(event.target.value)} placeholder="e.g. New business" maxLength={200} required /><button className="rounded bg-slate-900 px-4 py-2 text-white disabled:opacity-50" disabled={!name.trim() || create.isPending}>Add pipeline</button></form> : null}{create.isError ? <p role="alert" className="text-red-700">The pipeline could not be saved. Please try again.</p> : null}{query.data.items.length === 0 ? <p className="rounded border border-dashed p-6 text-slate-600">No pipelines yet.</p> : <ul className="divide-y rounded border">{query.data.items.map((pipeline) => <li key={pipeline.id} className="p-4"><h3 className="font-medium">{pipeline.name ?? pipeline.id}</h3><p className="text-sm text-slate-500">Created {new Date(pipeline.createdAt).toLocaleDateString()}</p></li>)}</ul>}</section>;
}
function ReadOnlyWorkspace({ organizationID, entity }: { organizationID: string; entity: Exclude<CRMEntity, "companies" | "contacts" | "pipelines"> }) { const query = useQuery({ queryKey: ["crm", organizationID, entity], queryFn: () => listCRM(organizationID, entity) }); if (query.isPending) return <p>Loading {entity}...</p>; if (query.isError) return <p role="alert">Unable to load {entity}.</p>; return <section aria-labelledby={`${entity}-heading`}><h2 id={`${entity}-heading`} className="text-xl font-semibold">{entityLabels[entity]}</h2><p className="mb-5 text-sm text-slate-600">{entity === "deals" ? "Review the current sales pipeline and deal values." : `Browse ${entity} recorded for this organization.`}</p>{query.data.items.length === 0 ? <p className="rounded border border-dashed p-6 text-slate-600">No {entity} yet.</p> : <ul className="divide-y rounded border">{query.data.items.map((item) => <li key={item.id} className="p-4 font-medium">{item.name ?? item.id}</li>)}</ul>}</section>; }
export function CRMAdmin({ organizationID, permissions }: { organizationID: string; permissions: readonly string[] }) { const visible = sections.filter((entity) => hasPermission(permissions, `crm.${entity}.view`)); const [entity, setEntity] = useState<CRMEntity>(visible[0] ?? "companies"); useEffect(() => { if (!visible.includes(entity)) setEntity(visible[0] ?? "companies"); }, [entity, visible.join(",")]); if (visible.length === 0) return <main className="p-8">You do not have permission to view CRM records.</main>; return <main className="mx-auto max-w-6xl p-8"><header><h1 className="text-2xl font-semibold">CRM workspace</h1><p className="mt-1 text-slate-600">Manage customer accounts and follow the sales pipeline.</p></header><nav aria-label="CRM sections" className="my-6 flex flex-wrap gap-2">{visible.map((item) => <button aria-pressed={entity === item} className="rounded border px-3 py-1 capitalize aria-pressed:bg-slate-900 aria-pressed:text-white" key={item} onClick={() => setEntity(item)}>{entityLabels[item]}</button>)}</nav>{entity === "companies" ? <CompaniesWorkspace organizationID={organizationID} permissions={permissions} /> : entity === "contacts" ? <ContactsWorkspace organizationID={organizationID} permissions={permissions} /> : entity === "pipelines" ? <PipelinesWorkspace organizationID={organizationID} permissions={permissions} /> : <ReadOnlyWorkspace organizationID={organizationID} entity={entity} />}</main>; }
