import { useState } from "react";
import { useQuery } from "@tanstack/react-query";
import type { CRMEntity, CRMRecord, CursorPage } from "./contracts";

const sections: CRMEntity[] = ["companies", "contacts", "pipelines", "stages", "deals", "activities"];
async function listCRM(organizationID: string, entity: CRMEntity): Promise<CursorPage<CRMRecord>> {
  const response = await fetch(`/api/v1/organizations/${organizationID}/crm/${entity}`, { credentials: "include" });
  if (!response.ok) throw new Error(`Unable to load ${entity}`);
  return response.json() as Promise<CursorPage<CRMRecord>>;
}
export function CRMAdmin({ organizationID, permissions }: { organizationID: string; permissions: readonly string[] }) {
  const visible = sections.filter((entity) => permissions.includes(`crm.${entity}.view`));
  const [entity, setEntity] = useState<CRMEntity>(visible[0] ?? "companies");
  const query = useQuery({ queryKey: ["crm", organizationID, entity], queryFn: () => listCRM(organizationID, entity), enabled: visible.length > 0 });
  if (visible.length === 0) return <main className="p-8">You do not have permission to view CRM records.</main>;
  return <main className="p-8"><h1 className="text-2xl font-semibold">CRM</h1><nav aria-label="CRM sections" className="my-4 flex gap-2">{visible.map((item) => <button className="rounded border px-3 py-1 capitalize" key={item} onClick={() => setEntity(item)}>{item}</button>)}</nav>{query.isPending ? <p>Loading {entity}...</p> : query.isError ? <p role="alert">Unable to load {entity}.</p> : <ul>{query.data.items.map((item) => <li key={item.id}>{item.name ?? item.id}</li>)}</ul>}</main>;
}

