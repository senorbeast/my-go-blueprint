import { QueryClient, QueryClientProvider } from "@tanstack/react-query";
import { cleanup, fireEvent, render, screen } from "@testing-library/react";
import { afterEach, describe, expect, it, vi } from "vitest";
import { CRMAdmin } from "./crm-admin";

describe("CRMAdmin", () => {
  afterEach(() => { cleanup(); vi.restoreAllMocks(); });
  it("hides CRM data when the principal has no permissions", () => {
    render(<QueryClientProvider client={new QueryClient()}><CRMAdmin organizationID="org-1" permissions={[]} /></QueryClientProvider>);
    expect(screen.getByText(/do not have permission/i)).toBeInTheDocument();
  });

  it("shows all CRM sections and company actions to a platform administrator", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(JSON.stringify({ items: [{ id: "company-1", organizationID: "org-1", name: "Acme Demo", createdAt: "2026-07-17T00:00:00Z" }], hasMore: false }), { status: 200 }));
    render(<QueryClientProvider client={new QueryClient({ defaultOptions: { queries: { retry: false } } })}><CRMAdmin organizationID="org-1" permissions={["platform.admin"]} /></QueryClientProvider>);
    expect(await screen.findByText("Acme Demo")).toBeInTheDocument();
    expect(screen.getByRole("button", { name: "Add company" })).toBeInTheDocument();
    expect(screen.getByRole("button", { name: "Rename" })).toBeInTheDocument();
    expect(screen.getByRole("button", { name: "Deals" })).toBeInTheDocument();
  });

  it("creates a company and refreshes the company workspace", async () => {
    const fetch = vi.spyOn(globalThis, "fetch")
      .mockResolvedValueOnce(new Response(JSON.stringify({ items: [], hasMore: false }), { status: 200 }))
      .mockResolvedValueOnce(new Response(JSON.stringify({ id: "company-1", organizationID: "org-1", name: "Acme", createdAt: "2026-07-17T00:00:00Z" }), { status: 200 }));
    const queryClient = new QueryClient({ defaultOptions: { queries: { retry: false } } });
    render(<QueryClientProvider client={queryClient}><CRMAdmin organizationID="org-1" permissions={["crm.companies.view", "crm.companies.create", "crm.companies.update"]} /></QueryClientProvider>);

    expect(await screen.findByText("No companies yet.")).toBeInTheDocument();
    fireEvent.change(screen.getByLabelText("Company name"), { target: { value: "Acme" } });
    fireEvent.click(screen.getByRole("button", { name: "Add company" }));

    expect(await screen.findByText("Acme")).toBeInTheDocument();
    expect(fetch).toHaveBeenLastCalledWith("/api/v1/organizations/org-1/crm/companies", expect.objectContaining({ method: "POST" }));
  });

  it("creates a contact with an optional email address", async () => {
    const fetch = vi.spyOn(globalThis, "fetch")
      .mockResolvedValueOnce(new Response(JSON.stringify({ items: [], hasMore: false }), { status: 200 }))
      .mockResolvedValueOnce(new Response(JSON.stringify({ id: "contact-1", organizationID: "org-1", name: "Ada", email: "ada@example.test", createdAt: "2026-07-17T00:00:00Z" }), { status: 200 }));
    const queryClient = new QueryClient({ defaultOptions: { queries: { retry: false } } });
    render(<QueryClientProvider client={queryClient}><CRMAdmin organizationID="org-1" permissions={["crm.contacts.view", "crm.contacts.create"]} /></QueryClientProvider>);

    fireEvent.click(await screen.findByRole("button", { name: "Contacts" }));
    expect(await screen.findByText("No contacts yet.")).toBeInTheDocument();
    fireEvent.change(screen.getByLabelText("Contact name"), { target: { value: "Ada" } });
    fireEvent.change(screen.getByLabelText("Contact email"), { target: { value: "ada@example.test" } });
    fireEvent.click(screen.getByRole("button", { name: "Add contact" }));

    expect(await screen.findByText("ada@example.test")).toBeInTheDocument();
    expect(fetch).toHaveBeenLastCalledWith("/api/v1/organizations/org-1/crm/contacts", expect.objectContaining({ method: "POST", body: JSON.stringify({ name: "Ada", email: "ada@example.test" }) }));
  });

  it("shows the pipeline creation form only with create permission", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(JSON.stringify({ items: [], hasMore: false }), { status: 200 }));
    const queryClient = new QueryClient({ defaultOptions: { queries: { retry: false } } });
    render(<QueryClientProvider client={queryClient}><CRMAdmin organizationID="org-1" permissions={["crm.pipelines.view"]} /></QueryClientProvider>);

    expect(await screen.findByText("No pipelines yet.")).toBeInTheDocument();
    expect(screen.queryByRole("button", { name: "Add pipeline" })).not.toBeInTheDocument();
  });

  it("creates a pipeline through the CRM pipeline endpoint", async () => {
    const fetch = vi.spyOn(globalThis, "fetch")
      .mockResolvedValueOnce(new Response(JSON.stringify({ items: [], hasMore: false }), { status: 200 }))
      .mockResolvedValueOnce(new Response(JSON.stringify({ id: "pipeline-1", organizationID: "org-1", name: "Sales", createdAt: "2026-07-17T00:00:00Z" }), { status: 200 }));
    const queryClient = new QueryClient({ defaultOptions: { queries: { retry: false } } });
    render(<QueryClientProvider client={queryClient}><CRMAdmin organizationID="org-1" permissions={["crm.pipelines.view", "crm.pipelines.create"]} /></QueryClientProvider>);

    expect(await screen.findByText("No pipelines yet.")).toBeInTheDocument();
    fireEvent.change(screen.getByLabelText("Pipeline name"), { target: { value: "Sales" } });
    fireEvent.click(screen.getByRole("button", { name: "Add pipeline" }));

    expect(await screen.findByText("Sales")).toBeInTheDocument();
    expect(fetch).toHaveBeenLastCalledWith("/api/v1/organizations/org-1/crm/pipelines", expect.objectContaining({ method: "POST", body: JSON.stringify({ name: "Sales" }) }));
  });
});
