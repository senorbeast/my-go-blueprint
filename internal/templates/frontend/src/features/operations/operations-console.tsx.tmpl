import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query";
import { useState } from "react";
import type { FormEvent } from "react";

type Job = { id: string; name: string; state: string; runAt: string; attempts: number; maxAttempts: number };
type Snapshot = { counts: Record<string, number>; recent: Job[]; workers: { name: string; handler: string; pollInterval: string; lease: string }[]; cron: { name: string; schedule: string; enqueues: string }[] };
const states = ["queued", "running", "completed", "dead"];
function csrfHeader(): Record<string, string> { const token = document.cookie.split("; ").find((entry) => entry.startsWith("csrf_token="))?.slice("csrf_token=".length); return token ? { "X-CSRF-Token": decodeURIComponent(token) } : {}; }
async function request<T>(path: string, init?: RequestInit): Promise<T> { const response = await fetch(path, { credentials: "include", ...init, headers: { "Content-Type": "application/json", ...csrfHeader(), ...init?.headers } }); if (!response.ok) throw new Error(`Request failed (${response.status})`); return response.json() as Promise<T>; }

{{if .Email}}function EmailComposer() {
  const client = useQueryClient(); const [to, setTo] = useState(""); const [subject, setSubject] = useState(""); const [text, setText] = useState("");
  const send = useMutation({ mutationFn: () => request<{ jobId: string }>("/api/v1/email/messages", { method: "POST", body: JSON.stringify({ to: to.trim(), subject: subject.trim(), text: text.trim() }) }), onSuccess: () => { setTo(""); setSubject(""); setText(""); void client.invalidateQueries({ queryKey: ["operations"] }); } });
  function submit(event: FormEvent<HTMLFormElement>) { event.preventDefault(); send.mutate(); }
  return <section className="rounded-lg border bg-card p-5"><h2 className="text-lg font-semibold">Queue an email</h2><p className="mt-1 text-sm text-muted-foreground">Development delivery uses the log adapter. The message body is never shown in the queue inspector.</p><form className="mt-4 grid gap-3" onSubmit={submit}><label className="text-sm font-medium">Recipient<input aria-label="Recipient" className="mt-1 w-full rounded border bg-background px-3 py-2" value={to} onChange={(event) => setTo(event.target.value)} type="email" required /></label><label className="text-sm font-medium">Subject<input aria-label="Subject" className="mt-1 w-full rounded border bg-background px-3 py-2" value={subject} onChange={(event) => setSubject(event.target.value)} maxLength={200} required /></label><label className="text-sm font-medium">Message<textarea aria-label="Message" className="mt-1 min-h-28 w-full rounded border bg-background px-3 py-2" value={text} onChange={(event) => setText(event.target.value)} maxLength={20000} required /></label><button className="w-fit rounded bg-primary px-4 py-2 text-sm font-medium text-primary-foreground disabled:opacity-50" disabled={send.isPending}>{send.isPending ? "Queuing…" : "Queue email"}</button></form>{send.isSuccess && <p className="mt-3 text-sm text-emerald-700">Queued as {send.data.jobId}.</p>}{send.isError && <p role="alert" className="mt-3 text-sm text-destructive">The email could not be queued. Check the fields and try again.</p>}</section>;
}
{{end}}

export function OperationsConsole() {
  const snapshot = useQuery({ queryKey: ["operations"], queryFn: () => request<Snapshot>("/api/v1/operations/jobs"), refetchInterval: 5000 });
  if (snapshot.isPending) return <main className="p-8">Loading operations…</main>;
  if (snapshot.isError) return <main className="p-8" role="alert">Unable to load operations. Sign in with an administrator account and confirm the API is running.</main>;
  const data = snapshot.data;
  return <main className="mx-auto max-w-7xl space-y-8 p-8"><header><p className="text-sm font-medium text-muted-foreground">Development observability</p><h1 className="text-3xl font-semibold tracking-tight">Operations</h1><p className="mt-2 max-w-3xl text-muted-foreground">Queue state refreshes every five seconds. This reports durable work and configured processes; use worker and scheduler logs to confirm that OS processes are currently alive.</p></header>{{if .Email}}<EmailComposer />{{end}}<section className="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">{states.map((state) => <article key={state} className="rounded-lg border bg-card p-4"><p className="text-sm capitalize text-muted-foreground">{state}</p><p className="mt-2 text-3xl font-semibold">{data.counts[state] ?? 0}</p></article>)}</section><section className="rounded-lg border bg-card p-5"><h2 className="text-lg font-semibold">Worker configuration</h2><div className="mt-3 grid gap-3 md:grid-cols-2">{data.workers.map((worker) => <div key={worker.name} className="rounded border p-3 text-sm"><p className="font-medium">{worker.name}</p><p className="mt-1 text-muted-foreground">Handlers: {worker.handler}</p><p className="text-muted-foreground">Poll: {worker.pollInterval} · Lease: {worker.lease}</p></div>)}</div></section><section className="rounded-lg border bg-card p-5"><h2 className="text-lg font-semibold">Cron schedules</h2>{data.cron.length === 0 ? <p className="mt-3 text-sm text-muted-foreground">No cron schedules are selected for this template.</p> : <ul className="mt-3 space-y-2">{data.cron.map((cron) => <li key={cron.name} className="rounded border p-3 text-sm"><span className="font-medium">{cron.name}</span><span className="text-muted-foreground"> · {cron.schedule} · enqueues {cron.enqueues}</span></li>)}</ul>}</section><section className="rounded-lg border bg-card p-5"><h2 className="text-lg font-semibold">Recent queue activity</h2><div className="mt-3 overflow-x-auto"><table className="w-full text-left text-sm"><thead className="border-b text-muted-foreground"><tr><th className="p-2">Job</th><th className="p-2">State</th><th className="p-2">Attempts</th><th className="p-2">Scheduled</th></tr></thead><tbody>{data.recent.map((job) => <tr key={job.id} className="border-b last:border-0"><td className="p-2"><p className="font-medium">{job.name}</p><p className="font-mono text-xs text-muted-foreground">{job.id}</p></td><td className="p-2 capitalize">{job.state}</td><td className="p-2">{job.attempts}/{job.maxAttempts}</td><td className="p-2">{new Date(job.runAt).toLocaleString()}</td></tr>)}</tbody></table>{data.recent.length === 0 && <p className="p-3 text-sm text-muted-foreground">No jobs have been queued yet.</p>}</div></section></main>;
}
